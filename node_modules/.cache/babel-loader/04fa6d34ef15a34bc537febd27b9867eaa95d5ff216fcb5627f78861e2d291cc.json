{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport axios from 'axios';\nexport default {\n  __name: 'ProfessorAssignments',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const assignments = ref([]);\n    const loading = ref(true);\n    onMounted(async () => {\n      try {\n        const res = await axios.get('http://localhost:8000/api/assignments'); // 🔧 URL은 실제 API에 맞게 조정\n        assignments.value = res.data;\n      } catch (err) {\n        console.error('과제 목록 로딩 실패:', err);\n        assignments.value = [];\n      } finally {\n        loading.value = false;\n      }\n    });\n    const __returned__ = {\n      assignments,\n      loading,\n      ref,\n      onMounted,\n      get axios() {\n        return axios;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","axios","assignments","loading","res","get","value","data","err","console","error"],"sources":["C:/Users/rlaal/abcde/test/src/views/ProfessorAssignments.vue"],"sourcesContent":["<template>\r\n  <div class=\"container mt-5\">\r\n    <h2 class=\"mb-4\">📝 교수용 과제 관리</h2>\r\n\r\n    <div v-if=\"loading\" class=\"text-center\">\r\n      <div class=\"spinner-border\" role=\"status\">\r\n        <span class=\"visually-hidden\">Loading...</span>\r\n      </div>\r\n    </div>\r\n\r\n    <div v-else-if=\"assignments.length === 0\" class=\"alert alert-info\">\r\n      현재 제출된 과제가 없습니다.\r\n    </div>\r\n\r\n    <div v-else>\r\n      <div v-for=\"assignment in assignments\" :key=\"assignment.id\" class=\"card mb-4 shadow-sm\">\r\n        <div class=\"card-body\">\r\n          <h5 class=\"card-title\">👤 {{ assignment.student }}</h5>\r\n          <p class=\"card-text text-muted\">📅 제출일: {{ assignment.submitted_at }}</p>\r\n\r\n          <ul class=\"list-group list-group-flush\">\r\n            <li\r\n              v-for=\"file in assignment.files\"\r\n              :key=\"file.filename\"\r\n              class=\"list-group-item d-flex justify-content-between align-items-center\"\r\n            >\r\n              {{ file.filename }}\r\n              <a :href=\"file.url\" class=\"btn btn-sm btn-outline-primary\" target=\"_blank\" download>\r\n                다운로드\r\n              </a>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport axios from 'axios'\r\n\r\nconst assignments = ref([])\r\nconst loading = ref(true)\r\n\r\nonMounted(async () => {\r\n  try {\r\n    const res = await axios.get('http://localhost:8000/api/assignments') // 🔧 URL은 실제 API에 맞게 조정\r\n    assignments.value = res.data\r\n  } catch (err) {\r\n    console.error('과제 목록 로딩 실패:', err)\r\n    assignments.value = []\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.card-title {\r\n  font-weight: 600;\r\n}\r\n</style>\r\n"],"mappings":"AAuCA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,OAAOC,KAAK,MAAM,OAAO;;;;;;;IAEzB,MAAMC,WAAW,GAAGH,GAAG,CAAC,EAAE,CAAC;IAC3B,MAAMI,OAAO,GAAGJ,GAAG,CAAC,IAAI,CAAC;IAEzBC,SAAS,CAAC,YAAY;MACpB,IAAI;QACF,MAAMI,GAAG,GAAG,MAAMH,KAAK,CAACI,GAAG,CAAC,uCAAuC,CAAC,EAAC;QACrEH,WAAW,CAACI,KAAK,GAAGF,GAAG,CAACG,IAAI;MAC9B,CAAC,CAAC,OAAOC,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,cAAc,EAAEF,GAAG,CAAC;QAClCN,WAAW,CAACI,KAAK,GAAG,EAAE;MACxB,CAAC,SAAS;QACRH,OAAO,CAACG,KAAK,GAAG,KAAK;MACvB;IACF,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}