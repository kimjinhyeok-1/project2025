{"ast":null,"code":"export default {\n  name: \"ProfessorReviewView\",\n  data() {\n    return {\n      reviewItems: []\n    };\n  },\n  mounted() {\n    // 수업 중 저장된 screenshotLog를 불러오기\n    const raw = sessionStorage.getItem(\"screenshotLog\");\n    if (raw) {\n      this.reviewItems = JSON.parse(raw);\n    }\n  }\n};","map":{"version":3,"names":["name","data","reviewItems","mounted","raw","sessionStorage","getItem","JSON","parse"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\views\\ProfessorReviewView.vue"],"sourcesContent":["<template>\r\n    <div class=\"review-container text-center mt-5\">\r\n      <h2>📚 수업 복습 보기</h2>\r\n      <p class=\"text-muted\">이번 수업 동안 인식된 키워드 문장과 그 시점의 화면 캡처입니다.</p>\r\n  \r\n      <div v-if=\"reviewItems.length\" class=\"mt-5\">\r\n        <div\r\n          v-for=\"(item, index) in reviewItems\"\r\n          :key=\"index\"\r\n          class=\"review-item mb-5\"\r\n        >\r\n          <img :src=\"item.screenshot\" class=\"screenshot mb-2\" />\r\n          <p><strong>⏱ 타임스탬프:</strong> {{ item.timestamp }}</p>\r\n          <p><strong>🎙 인식된 문장:</strong> \"{{ item.transcript }}\"</p>\r\n          <hr />\r\n        </div>\r\n      </div>\r\n      <div v-else>\r\n        <p>녹음 세션 중 저장된 스크린샷이 아직 없습니다.</p>\r\n      </div>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  export default {\r\n    name: \"ProfessorReviewView\",\r\n    data() {\r\n      return {\r\n        reviewItems: [],\r\n      };\r\n    },\r\n    mounted() {\r\n      // 수업 중 저장된 screenshotLog를 불러오기\r\n      const raw = sessionStorage.getItem(\"screenshotLog\");\r\n      if (raw) {\r\n        this.reviewItems = JSON.parse(raw);\r\n      }\r\n    },\r\n  };\r\n  </script>\r\n  \r\n  <style scoped>\r\n  .review-container {\r\n    max-width: 900px;\r\n    margin: auto;\r\n    padding: 30px;\r\n  }\r\n  .screenshot {\r\n    max-width: 100%;\r\n    border-radius: 10px;\r\n    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\r\n  }\r\n  .review-item {\r\n    background-color: #f8f9fa;\r\n    padding: 20px;\r\n    border-radius: 12px;\r\n    box-shadow: 0 0 6px rgba(0, 0, 0, 0.05);\r\n  }\r\n  </style>\r\n  "],"mappings":"AAwBE,eAAe;EACbA,IAAI,EAAE,qBAAqB;EAC3BC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE;IACf,CAAC;EACH,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR;IACA,MAAMC,GAAE,GAAIC,cAAc,CAACC,OAAO,CAAC,eAAe,CAAC;IACnD,IAAIF,GAAG,EAAE;MACP,IAAI,CAACF,WAAU,GAAIK,IAAI,CAACC,KAAK,CAACJ,GAAG,CAAC;IACpC;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}