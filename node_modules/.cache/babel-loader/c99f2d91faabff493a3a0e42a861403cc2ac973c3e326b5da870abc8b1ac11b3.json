{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport axios from 'axios';\nexport default {\n  __name: 'ProfessorQnA',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const activeTab = ref('summary');\n    const summary = ref('');\n    const fullChat = ref([]);\n    onMounted(async () => {\n      try {\n        const summaryRes = await axios.get('http://192.168.50.24:8000/chat/summary');\n        summary.value = summaryRes.data;\n        const chatRes = await axios.get('http://192.168.50.24:8000/chat/logs');\n        fullChat.value = chatRes.data;\n      } catch (err) {\n        console.error('데이터 로딩 실패:', err);\n        summary.value = '❌ 요약 데이터를 불러올 수 없습니다.';\n        fullChat.value = [{\n          role: 'system',\n          content: '❌ 대화 데이터를 불러올 수 없습니다.'\n        }];\n      }\n    });\n    const __returned__ = {\n      activeTab,\n      summary,\n      fullChat,\n      ref,\n      onMounted,\n      get axios() {\n        return axios;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","axios","activeTab","summary","fullChat","summaryRes","get","value","data","chatRes","err","console","error","role","content"],"sources":["C:/Users/user/test/src/views/ProfessorQnA.vue"],"sourcesContent":["<template>\r\n  <div class=\"container mt-5 text-center\">\r\n    <h2>❓ 질문 & 답변 확인하기</h2>\r\n\r\n    <!-- 탭 메뉴 -->\r\n    <ul class=\"nav nav-tabs mt-4 justify-content-center\">\r\n      <li class=\"nav-item\">\r\n        <a class=\"nav-link\" :class=\"{ active: activeTab === 'summary' }\" @click=\"activeTab = 'summary'\">요약 보기</a>\r\n      </li>\r\n      <li class=\"nav-item\">\r\n        <a class=\"nav-link\" :class=\"{ active: activeTab === 'fullchat' }\" @click=\"activeTab = 'fullchat'\">전체 대화 보기</a>\r\n      </li>\r\n      <li class=\"nav-item\">\r\n        <a class=\"nav-link\" :class=\"{ active: activeTab === 'resources' }\" @click=\"activeTab = 'resources'\">자료 보기</a>\r\n      </li>\r\n    </ul>\r\n\r\n    <!-- 탭 콘텐츠 -->\r\n    <div class=\"tab-content mt-4 text-start\">\r\n      <div v-if=\"activeTab === 'summary'\">\r\n        <h5>📋 질문 요약</h5>\r\n        <p>{{ summary || '요약 데이터를 불러오는 중입니다...' }}</p>\r\n      </div>\r\n\r\n      <div v-if=\"activeTab === 'fullchat'\">\r\n        <h5>💬 전체 대화 내용</h5>\r\n        <ul class=\"list-group\">\r\n          <li\r\n            v-for=\"(msg, index) in fullChat\"\r\n            :key=\"index\"\r\n            class=\"list-group-item\"\r\n          >\r\n            <strong>{{ msg.role === 'user' ? '학생' : 'GPT' }}:</strong> {{ msg.content }}\r\n          </li>\r\n        </ul>\r\n      </div>\r\n\r\n      <div v-if=\"activeTab === 'resources'\">\r\n        <h5>📂 자료 보기</h5>\r\n        <p>자료 기능은 추후 추가될 예정입니다.</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport axios from 'axios'\r\n\r\nconst activeTab = ref('summary')\r\nconst summary = ref('')\r\nconst fullChat = ref([])\r\n\r\nonMounted(async () => {\r\n  try {\r\n    const summaryRes = await axios.get('http://192.168.50.24:8000/chat/summary')\r\n    summary.value = summaryRes.data\r\n\r\n    const chatRes = await axios.get('http://192.168.50.24:8000/chat/logs')\r\n    fullChat.value = chatRes.data\r\n  } catch (err) {\r\n    console.error('데이터 로딩 실패:', err)\r\n    summary.value = '❌ 요약 데이터를 불러올 수 없습니다.'\r\n    fullChat.value = [{ role: 'system', content: '❌ 대화 데이터를 불러올 수 없습니다.' }]\r\n  }\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.nav-link {\r\n  cursor: pointer;\r\n}\r\n</style>\r\n"],"mappings":"AA8CA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,OAAOC,KAAK,MAAM,OAAO;;;;;;;IAEzB,MAAMC,SAAS,GAAGH,GAAG,CAAC,SAAS,CAAC;IAChC,MAAMI,OAAO,GAAGJ,GAAG,CAAC,EAAE,CAAC;IACvB,MAAMK,QAAQ,GAAGL,GAAG,CAAC,EAAE,CAAC;IAExBC,SAAS,CAAC,YAAY;MACpB,IAAI;QACF,MAAMK,UAAU,GAAG,MAAMJ,KAAK,CAACK,GAAG,