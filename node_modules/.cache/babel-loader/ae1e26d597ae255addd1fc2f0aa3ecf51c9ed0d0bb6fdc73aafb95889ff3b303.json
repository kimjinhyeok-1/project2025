{"ast":null,"code":"import { useRoute } from 'vue-router';\nimport { computed } from 'vue';\nimport NavbarComponent from './components/NavbarComponent.vue';\nexport default {\n  components: {\n    NavbarComponent\n  },\n  setup() {\n    const route = useRoute();\n    const isHome = computed(() => route?.path === '/'); // ✅ 안전하게 체크\n    return {\n      isHome\n    };\n  }\n};","map":{"version":3,"names":["useRoute","computed","NavbarComponent","components","setup","route","isHome","path"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\App.vue"],"sourcesContent":["<template>\n  <div>\n    <!-- 현재 경로가 '/'가 아닐 때만 네비게이션 바 표시 -->\n    <NavbarComponent v-if=\"!isHome\" />\n\n    <!-- 라우터 뷰는 항상 표시 -->\n    <div class=\"container mt-4\">\n      <router-view></router-view>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { useRoute } from 'vue-router'\nimport { computed } from 'vue'\nimport NavbarComponent from './components/NavbarComponent.vue'\n\nexport default {\n  components: {\n    NavbarComponent,\n  },\n  setup() {\n    const route = useRoute()\n    const isHome = computed(() => route?.path === '/') // ✅ 안전하게 체크\n    return {\n      isHome,\n    }\n  },\n}\n</script>\n"],"mappings":"AAaA,SAASA,QAAO,QAAS,YAAW;AACpC,SAASC,QAAO,QAAS,KAAI;AAC7B,OAAOC,eAAc,MAAO,kCAAiC;AAE7D,eAAe;EACbC,UAAU,EAAE;IACVD;EACF,CAAC;EACDE,KAAKA,CAAA,EAAG;IACN,MAAMC,KAAI,GAAIL,QAAQ,CAAC;IACvB,MAAMM,MAAK,GAAIL,QAAQ,CAAC,MAAMI,KAAK,EAAEE,IAAG,KAAM,GAAG,GAAE;IACnD,OAAO;MACLD;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}