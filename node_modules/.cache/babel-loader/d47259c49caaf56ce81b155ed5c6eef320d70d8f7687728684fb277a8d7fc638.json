{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport axios from 'axios';\nexport default {\n  __name: 'ProfessorAssignments',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const assignments = ref([]);\n    const loading = ref(true);\n    onMounted(async () => {\n      try {\n        const res = await axios.get('http://localhost:8000/api/assignments'); // ✨ 실제 API 주소로 교체\n        assignments.value = res.data;\n      } catch (err) {\n        console.error('과제 공지 불러오기 실패:', err);\n      } finally {\n        loading.value = false;\n      }\n    });\n    const __returned__ = {\n      assignments,\n      loading,\n      ref,\n      onMounted,\n      get axios() {\n        return axios;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","axios","assignments","loading","res","get","value","data","err","console","error"],"sources":["C:/Users/rlaal/abcde/test/src/views/ProfessorAssignments.vue"],"sourcesContent":["<template>\r\n  <div class=\"container mt-5\">\r\n    <h2 class=\"mb-4\">📝 교수용 과제 공지 목록</h2>\r\n\r\n    <div class=\"d-flex justify-content-end mb-3\">\r\n      <router-link to=\"/professor/assignments/new\" class=\"btn btn-primary\">\r\n        ➕ 새 과제 공지 작성\r\n      </router-link>\r\n    </div>\r\n\r\n    <div v-if=\"loading\" class=\"text-center\">\r\n      <div class=\"spinner-border\" role=\"status\">\r\n        <span class=\"visually-hidden\">Loading...</span>\r\n      </div>\r\n    </div>\r\n\r\n    <div v-else-if=\"assignments.length === 0\" class=\"alert alert-info\">\r\n      등록된 과제 공지가 없습니다.\r\n    </div>\r\n\r\n    <div v-else>\r\n      <div\r\n        v-for=\"assignment in assignments\"\r\n        :key=\"assignment.id\"\r\n        class=\"card mb-3 shadow-sm\"\r\n      >\r\n        <div class=\"card-body\">\r\n          <h5>{{ assignment.title }}</h5>\r\n          <p class=\"text-muted\">{{ assignment.description }}</p>\r\n          <p>📅 마감일: {{ assignment.due }}</p>\r\n          <router-link :to=\"`/professor/assignments/${assignment.id}/submissions`\" class=\"btn btn-outline-primary\">\r\n            제출 현황 보기\r\n          </router-link>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport axios from 'axios'\r\n\r\nconst assignments = ref([])\r\nconst loading = ref(true)\r\n\r\nonMounted(async () => {\r\n  try {\r\n    const res = await axios.get('http://localhost:8000/api/assignments') // ✨ 실제 API 주소로 교체\r\n    assignments.value = res.data\r\n  } catch (err) {\r\n    console.error('과제 공지 불러오기 실패:', err)\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n})\r\n</script>\r\n"],"mappings":"AAwCA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,OAAOC,KAAK,MAAM,OAAO;;;;;;;IAEzB,MAAMC,WAAW,GAAGH,GAAG,CAAC,EAAE,CAAC;IAC3B,MAAMI,OAAO,GAAGJ,GAAG,CAAC,IAAI,CAAC;IAEzBC,SAAS,CAAC,YAAY;MACpB,IAAI;QACF,MAAMI,GAAG,GAAG,MAAMH,KAAK,CAACI,GAAG,CAAC,uCAAuC,CAAC,EAAC;QACrEH,WAAW,CAACI,KAAK,GAAGF,GAAG,CAACG,IAAI;MAC9B,CAAC,CAAC,OAAOC,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,gBAAgB,EAAEF,GAAG,CAAC;MACtC,CAAC,SAAS;QACRL,OAAO,CAACG,KAAK,GAAG,KAAK;MACvB;IACF,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}