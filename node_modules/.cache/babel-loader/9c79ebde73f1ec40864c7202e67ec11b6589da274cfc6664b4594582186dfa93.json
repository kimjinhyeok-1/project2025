{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, onMounted } from 'vue';\nimport { useRouter } from 'vue-router';\nexport default {\n  name: 'NavbarComponent',\n  setup() {\n    const isLoggedIn = ref(false);\n    const router = useRouter();\n    const checkLogin = () => {\n      isLoggedIn.value = !!localStorage.getItem('user');\n    };\n    const logout = () => {\n      localStorage.removeItem('user');\n      isLoggedIn.value = false;\n      router.push('/');\n    };\n    onMounted(() => {\n      checkLogin();\n    });\n    return {\n      isLoggedIn,\n      logout\n    };\n  }\n};","map":{"version":3,"names":["ref","onMounted","useRouter","name","setup","isLoggedIn","router","checkLogin","value","localStorage","getItem","logout","removeItem","push"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\components\\NavbarComponent.vue"],"sourcesContent":["<template>\r\n  <nav class=\"navbar navbar-expand-lg navbar-light bg-white shadow py-3 mb-4\">\r\n    <div class=\"container-fluid\">\r\n      <!-- 로고 텍스트 -->\r\n      <span class=\"navbar-brand text-primary fw-bold text-uppercase\">KOREATECH</span>\r\n\r\n      <!-- 햄버거 버튼 (모바일용) -->\r\n      <button\r\n        class=\"navbar-toggler\"\r\n        type=\"button\"\r\n        data-bs-toggle=\"collapse\"\r\n        data-bs-target=\"#navbarSupportedContent\"\r\n        aria-controls=\"navbarSupportedContent\"\r\n        aria-expanded=\"false\"\r\n        aria-label=\"Toggle navigation\"\r\n      >\r\n        <span class=\"navbar-toggler-icon\"></span>\r\n      </button>\r\n\r\n      <!-- 메뉴 항목 -->\r\n      <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\r\n        <ul class=\"navbar-nav me-auto mb-2 mb-lg-0\">\r\n          <li class=\"nav-item\">\r\n            <router-link class=\"nav-link text-gray-800 fw-semibold\" to=\"/student\">\r\n              <i class=\"fas fa-user-graduate me-1\"></i> 학생 페이지\r\n            </router-link>\r\n          </li>\r\n          <li class=\"nav-item\">\r\n            <router-link class=\"nav-link text-gray-800 fw-semibold\" to=\"/professor\">\r\n              <i class=\"fas fa-chalkboard-teacher me-1\"></i> 교수자 페이지\r\n            </router-link>\r\n          </li>\r\n        </ul>\r\n\r\n        <!-- 로그아웃 버튼 -->\r\n        <div v-if=\"isLoggedIn\" class=\"d-flex\">\r\n          <button class=\"btn btn-danger btn-sm\" @click=\"logout\">\r\n            <i class=\"fas fa-sign-out-alt me-1\"></i> 로그아웃\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </nav>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nexport default {\r\n  name: 'NavbarComponent',\r\n  setup() {\r\n    const isLoggedIn = ref(false)\r\n    const router = useRouter()\r\n\r\n    const checkLogin = () => {\r\n      isLoggedIn.value = !!localStorage.getItem('user')\r\n    }\r\n\r\n    const logout = () => {\r\n      localStorage.removeItem('user')\r\n      isLoggedIn.value = false\r\n      router.push('/')\r\n    }\r\n\r\n    onMounted(() => {\r\n      checkLogin()\r\n    })\r\n\r\n    return {\r\n      isLoggedIn,\r\n      logout,\r\n    }\r\n  },\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.navbar-brand {\r\n  font-size: 1.2rem;\r\n  letter-spacing: 1px;\r\n}\r\n\r\n.nav-link {\r\n  font-size: 0.95rem;\r\n}\r\n\r\n.btn-sm {\r\n  font-size: 0.85rem;\r\n  padding: 0.375rem 0.75rem;\r\n}\r\n</style>\r\n"],"mappings":";AA8CA,SAASA,GAAG,EAAEC,SAAQ,QAAS,KAAI;AACnC,SAASC,SAAQ,QAAS,YAAW;AAErC,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,KAAKA,CAAA,EAAG;IACN,MAAMC,UAAS,GAAIL,GAAG,CAAC,KAAK;IAC5B,MAAMM,MAAK,GAAIJ,SAAS,CAAC;IAEzB,MAAMK,UAAS,GAAIA,CAAA,KAAM;MACvBF,UAAU,CAACG,KAAI,GAAI,CAAC,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM;IAClD;IAEA,MAAMC,MAAK,GAAIA,CAAA,KAAM;MACnBF,YAAY,CAACG,UAAU,CAAC,MAAM;MAC9BP,UAAU,CAACG,KAAI,GAAI,KAAI;MACvBF,MAAM,CAACO,IAAI,CAAC,GAAG;IACjB;IAEAZ,SAAS,CAAC,MAAM;MACdM,UAAU,CAAC;IACb,CAAC;IAED,OAAO;MACLF,UAAU;MACVM;IACF;EACF;AACF","ignoreList"