{"ast":null,"code":"export default {\n  __name: 'StudentLayout',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // 여긴 setup 문법 사용 중이므로 별도 로직은 없음\n\n    const __returned__ = {};\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":[],"sources":["C:/Users/rlaal/abcde/test/src/views/StudentLayout.vue"],"sourcesContent":["<template>\r\n    <div class=\"dashboard-container\">\r\n      <!-- 왼쪽 사이드바 깃허브 연결 완료 -->\r\n      <aside class=\"sidebar\">\r\n        <router-link to=\"/student/qna\" class=\"sidebar-btn\">QnA</router-link>\r\n        <router-link to=\"/student/assignment\" class=\"sidebar-btn\">과제</router-link>\r\n      </aside>\r\n  \r\n      <!-- 오른쪽 메인 콘텐츠 -->\r\n      <section class=\"main-content\">\r\n        <router-view />\r\n      </section>\r\n    </div>\r\n  </template>\r\n  \r\n  <script setup>\r\n  // 여긴 setup 문법 사용 중이므로 별도 로직은 없음\r\n  </script>\r\n  \r\n  <style scoped>\r\n  .dashboard-container {\r\n    display: flex;\r\n    height: 100vh;\r\n    margin: 0;\r\n    padding: 0;\r\n  }\r\n  \r\n  /* 왼쪽 사이드바 스타일 */\r\n  .sidebar {\r\n    width: 250px;\r\n    background-color: #e3f2fd; /* 연한 하늘색 */\r\n    padding: 20px;\r\n    margin: 0;\r\n    border-right: 1px solid #ccc;\r\n    position: fixed;\r\n    top: 56px; /* 상단 네비게이션 바 높이 고려 */\r\n    left: 0;\r\n    bottom: 0;\r\n    box-sizing: border-box;\r\n  }\r\n  \r\n  /* 버튼 (router-link) 스타일 */\r\n  .sidebar-btn {\r\n    display: block;\r\n    width: 100%;\r\n    margin-bottom: 12px;\r\n    padding: 10px 15px;\r\n    background-color: white;\r\n    border: 1px solid #0d6efd;\r\n    border-radius: 10px;\r\n    color: #0d6efd;\r\n    font-weight: 500;\r\n    font-size: 14px;\r\n    cursor: pointer;\r\n    text-align: center;\r\n    text-decoration: none;\r\n    transition: all 0.2s;\r\n  }\r\n  \r\n  .sidebar-btn:hover {\r\n    background-color: #e0edff;\r\n  }\r\n  \r\n  .sidebar-btn.router-link-active {\r\n    background-color: #0d6efd; /* 상단바와 동일한 파랑 */\r\n    color: white;\r\n  }\r\n  \r\n  /* 메인 콘텐츠 영역 */\r\n  .main-content {\r\n    flex: 1;\r\n    margin-left: 250px; /* 사이드바 만큼 밀어줌 */\r\n    padding: 20px;\r\n    overflow-y: auto;\r\n  }\r\n  </style>\r\n  "],"mappings":";;;;;;;IAgBE","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}