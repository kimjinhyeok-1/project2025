{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref } from \"vue\";\nimport { sendMessageToChatGPT } from \"@/api/chatService\";\nexport default {\n  name: \"ChatComponent\",\n  setup() {\n    const messages = ref([]);\n    const userInput = ref(\"\");\n    const sendMessage = async () => {\n      if (userInput.value.trim() === \"\") return;\n      messages.value.push({\n        role: \"user\",\n        content: userInput.value\n      });\n      const response = await sendMessageToChatGPT(userInput.value);\n      messages.value.push({\n        role: \"assistant\",\n        content: response\n      });\n      userInput.value = \"\";\n    };\n    return {\n      messages,\n      userInput,\n      sendMessage\n    };\n  }\n};","map":{"version":3,"names":["ref","sendMessageToChatGPT","name","setup","messages","userInput","sendMessage","value","trim","push","role","content","response"],"sources":["C:\\Users\\user\\test\\src\\components\\ChatComponent.vue"],"sourcesContent":["<template>\r\n    <div class=\"chat-container\">\r\n      <h2>Chat with AI</h2>\r\n      <div class=\"chat-box\">\r\n        <div v-for=\"(message, index) in messages\" :key=\"index\" :class=\"message.role\">\r\n          {{ message.content }}\r\n        </div>\r\n      </div>\r\n      <div class=\"input-area\">\r\n        <input v-model=\"userInput\" placeholder=\"Type a message...\" @keyup.enter=\"sendMessage\" />\r\n        <button @click=\"sendMessage\">Send</button>\r\n      </div>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import { ref } from \"vue\";\r\n  import { sendMessageToChatGPT } from \"@/api/chatService\";\r\n  \r\n  export default {\r\n    name: \"ChatComponent\",\r\n    setup() {\r\n      const messages = ref([]);\r\n      const userInput = ref(\"\");\r\n  \r\n      const sendMessage = async () => {\r\n        if (userInput.value.trim() === \"\") return;\r\n  \r\n        messages.value.push({ role: \"user\", content: userInput.value });\r\n  \r\n        const response = await sendMessageToChatGPT(userInput.value);\r\n        messages.value.push({ role: \"assistant\", content: response });\r\n  \r\n        userInput.value = \"\";\r\n      };\r\n  \r\n      return { messages, userInput, sendMessage };\r\n    },\r\n  };\r\n  </script>\r\n  \r\n  <style scoped>\r\n  .chat-container {\r\n    width: 400px;\r\n    margin: auto;\r\n    text-align: center;\r\n    background: #f9f9f9;\r\n    padding: 10px;\r\n    border-radius: 5px;\r\n  }\r\n  .chat-box {\r\n    border: 1px solid #ddd;\r\n    height: 300px;\r\n    overflow-y: auto;\r\n    padding: 10px;\r\n    background: #fff;\r\n  }\r\n  .user {\r\n    text-align: right;\r\n    color: blue;\r\n  }\r\n  .assistant {\r\n    text-align: left;\r\n    color: green;\r\n  }\r\n  .input-area {\r\n    margin-top: 10px;\r\n    display: flex;\r\n  }\r\n  input {\r\n    flex: 1;\r\n    padding: 5px;\r\n  }\r\n  button {\r\n    padding: 5px 10px;\r\n    background: blue;\r\n    color: white;\r\n    border: none;\r\n    cursor: pointer;\r\n  }\r\n  </style>\r\n  "],"mappings":";AAgBE,SAASA,GAAE,QAAS,KAAK;AACzB,SAASC,oBAAmB,QAAS,mBAAmB;AAExD,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,KAAKA,CAAA,EAAG;IACN,MAAMC,QAAO,GAAIJ,GAAG,CAAC,EAAE,CAAC;IACxB,MAAMK,SAAQ,GAAIL,GAAG,CAAC,EAAE,CAAC;IAEzB,MAAMM,WAAU,GAAI,MAAAA,CAAA,KAAY;MAC9B,IAAID,SAAS,CAACE,KAAK,CAACC,IAAI,CAAC,MAAM,EAAE,EAAE;MAEnCJ,QAAQ,CAACG,KAAK,CAACE,IAAI,CAAC;QAAEC,IAAI,EAAE,MAAM;QAAEC,OAAO,EAAEN,SAAS,CAACE;MAAM,CAAC,CAAC;MAE/D,MAAMK,QAAO,GAAI,MAAMX,oBAAoB,CAACI,SAAS,CAACE,KAAK,CAAC;MAC5DH,QAAQ,CAACG,KAAK,CAACE,IAAI,CAAC;QAAEC,IAAI,EAAE,WAAW;QAAEC,OAAO,EAAEC;MAAS,CAAC,CAAC;MAE7DP,SAAS,CAACE,KAAI,GAAI,EAAE;IACtB,CAAC;IAED,OAAO;MAAEH,QAAQ;MAAEC,SAAS;MAAEC;IAAY,CAAC;EAC7C;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}