{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'LoginView',\n  data() {\n    return {\n      email: '',\n      password: ''\n    };\n  },\n  methods: {\n    async handleLogin() {\n      try {\n        // 여기에 백엔드 연동 코드 추가 예정\n        console.log('로그인 정보:', this.email, this.password);\n\n        // 임시로 이메일/비밀번호가 있으면 로그인 성공 처리\n        if (this.email && this.password) {\n          // 로그인 성공 시 HomeView로 이동\n          this.$router.push({\n            name: 'home'\n          });\n        } else {\n          alert('이메일과 비밀번호를 입력해주세요.');\n        }\n      } catch (error) {\n        console.error('로그인 오류:', error);\n        alert('로그인 실패');\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","email","password","methods","handleLogin","console","log","$router","push","alert","error"],"sources":["C:\\Users\\user\\test\\src\\views\\LoginView.vue"],"sourcesContent":["<!-- src/views/LoginView.vue -->\r\n<template>\r\n  <div class=\"d-flex justify-content-center align-items-center vh-100\">\r\n    <div class=\"card p-4 shadow\" style=\"min-width: 350px;\">\r\n      <h3 class=\"text-center mb-3\">로그인</h3>\r\n      <form @submit.prevent=\"handleLogin\">\r\n        <div class=\"mb-3\">\r\n          <label for=\"email\" class=\"form-label\">이메일</label>\r\n          <input type=\"email\" v-model=\"email\" class=\"form-control\" id=\"email\" required />\r\n        </div>\r\n        <div class=\"mb-3\">\r\n          <label for=\"password\" class=\"form-label\">비밀번호</label>\r\n          <input type=\"password\" v-model=\"password\" class=\"form-control\" id=\"password\" required />\r\n        </div>\r\n        <button type=\"submit\" class=\"btn btn-primary w-100\">로그인</button>\r\n      </form>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'LoginView',\r\n  data() {\r\n    return {\r\n      email: '',\r\n      password: '',\r\n    };\r\n  },\r\n  methods: {\r\n    async handleLogin() {\r\n      try {\r\n        // 여기에 백엔드 연동 코드 추가 예정\r\n        console.log('로그인 정보:', this.email, this.password);\r\n\r\n        // 임시로 이메일/비밀번호가 있으면 로그인 성공 처리\r\n        if (this.email && this.password) {\r\n          // 로그인 성공 시 HomeView로 이동\r\n          this.$router.push({ name: 'home' });\r\n        } else {\r\n          alert('이메일과 비밀번호를 입력해주세요.');\r\n        }\r\n      } catch (error) {\r\n        console.error('로그인 오류:', error);\r\n        alert('로그인 실패');\r\n      }\r\n    },\r\n  },\r\n};\r\n</script>\r\n"],"mappings":";AAqBA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE;IACZ,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,WAAWA,CAAA,EAAG;MAClB,IAAI;QACF;QACAC,OAAO,CAACC,GAAG,CAAC,SAAS,EAAE,IAAI,CAACL,KAAK,EAAE,IAAI,CAACC,QAAQ,CAAC;;QAEjD;QACA,IAAI,IAAI,CAACD,KAAI,IAAK,IAAI,CAACC,QAAQ,EAAE;UAC/B;UACA,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC;YAAET,IAAI,EAAE;UAAO,CAAC,CAAC;QACrC,OAAO;UACLU,KAAK,CAAC,oBAAoB,CAAC;QAC7B;MACF,EAAE,OAAOC,KAAK,EAAE;QACdL,OAAO,CAACK,KAAK,CAAC,SAAS,EAAEA,KAAK,CAAC;QAC/BD,KAAK,CAAC,QAAQ,CAAC;MACjB;IACF;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}