{"ast":null,"code":"import { computed } from 'vue';\nexport default {\n  name: \"NavbarComponent\",\n  setup() {\n    // 항상 최신 userRole을 반응형으로 가져오기\n    const userRole = computed(() => localStorage.getItem('userRole') || '');\n    const roleLabel = computed(() => {\n      if (userRole.value === 'teacher') return '교수자';\n      if (userRole.value === 'student') return '학생';\n      return '';\n    });\n    return {\n      userRole,\n      roleLabel\n    };\n  }\n};","map":{"version":3,"names":["computed","name","setup","userRole","localStorage","getItem","roleLabel","value"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\components\\NavbarComponent.vue"],"sourcesContent":["<template>\r\n  <nav class=\"navbar navbar-expand-lg bg-primary\">\r\n    <div class=\"container-fluid\">\r\n      <!-- 로고 -->\r\n      <span class=\"navbar-brand text-white fw-bold\">Koreatech</span>\r\n\r\n      <!-- 모바일 메뉴 토글 버튼 -->\r\n      <button\r\n        class=\"navbar-toggler\"\r\n        type=\"button\"\r\n        data-bs-toggle=\"collapse\"\r\n        data-bs-target=\"#navbarSupportedContent\"\r\n        aria-controls=\"navbarSupportedContent\"\r\n        aria-expanded=\"false\"\r\n        aria-label=\"Toggle navigation\"\r\n      >\r\n        <span class=\"navbar-toggler-icon\"></span>\r\n      </button>\r\n\r\n      <!-- 메뉴 영역 -->\r\n      <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\r\n        <!-- 왼쪽 메뉴 -->\r\n        <ul class=\"navbar-nav me-auto mb-2 mb-lg-0\">\r\n          <li class=\"nav-item\">\r\n            <router-link class=\"nav-link text-white\" to=\"/student\">Student</router-link>\r\n          </li>\r\n          <li class=\"nav-item\">\r\n            <router-link class=\"nav-link text-white\" to=\"/professor\">Professor</router-link>\r\n          </li>\r\n          <li class=\"nav-item dropdown\">\r\n            <a\r\n              class=\"nav-link dropdown-toggle text-white\"\r\n              href=\"#\"\r\n              role=\"button\"\r\n              data-bs-toggle=\"dropdown\"\r\n              aria-expanded=\"false\"\r\n            >\r\n              Dropdown\r\n            </a>\r\n            <ul class=\"dropdown-menu\">\r\n              <li><a class=\"dropdown-item\" href=\"#\">Action</a></li>\r\n              <li><a class=\"dropdown-item\" href=\"#\">Another action</a></li>\r\n              <li><hr class=\"dropdown-divider\" /></li>\r\n              <li><a class=\"dropdown-item\" href=\"#\">Something else here</a></li>\r\n            </ul>\r\n          </li>\r\n          <li class=\"nav-item\">\r\n            <a class=\"nav-link disabled text-white-50\" aria-disabled=\"true\">Disabled</a>\r\n          </li>\r\n        </ul>\r\n\r\n        <!-- 오른쪽 사용자 프로필 표시 -->\r\n        <div class=\"d-flex align-items-center text-white\">\r\n          <span v-if=\"roleLabel\" class=\"fw-semibold\">👤 {{ roleLabel }}</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </nav>\r\n</template>\r\n\r\n<script>\r\nimport { computed } from 'vue'\r\n\r\nexport default {\r\n  name: \"NavbarComponent\",\r\n  setup() {\r\n    // 항상 최신 userRole을 반응형으로 가져오기\r\n    const userRole = computed(() => localStorage.getItem('userRole') || '')\r\n\r\n    const roleLabel = computed(() => {\r\n      if (userRole.value === 'teacher') return '교수자'\r\n      if (userRole.value === 'student') return '학생'\r\n      return ''\r\n    })\r\n\r\n    return {\r\n      userRole,\r\n      roleLabel\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.navbar {\r\n  box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);\r\n}\r\n</style>\r\n"],"mappings":"AA6DA,SAASA,QAAO,QAAS,KAAI;AAE7B,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,KAAKA,CAAA,EAAG;IACN;IACA,MAAMC,QAAO,GAAIH,QAAQ,CAAC,MAAMI,YAAY,CAACC,OAAO,CAAC,UAAU,KAAK,EAAE;IAEtE,MAAMC,SAAQ,GAAIN,QAAQ,CAAC,MAAM;MAC/B,IAAIG,QAAQ,CAACI,KAAI,KAAM,SAAS,EAAE,OAAO,KAAI;MAC7C,IAAIJ,QAAQ,CAACI,KAAI,KAAM,SAAS,EAAE,OAAO,IAAG;MAC5C,OAAO,EAAC;IACV,CAAC;IAED,OAAO;MACLJ,QAAQ;MACRG;IACF;EACF;AACF","ignoreList":[]},"metadat