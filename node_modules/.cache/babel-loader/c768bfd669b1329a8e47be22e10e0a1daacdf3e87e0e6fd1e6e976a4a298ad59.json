{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.iterator.some.js\";\nimport \"core-js/modules/web.url-search-params.delete.js\";\nimport \"core-js/modules/web.url-search-params.has.js\";\nimport \"core-js/modules/web.url-search-params.size.js\";\nimport { uploadSnapshot } from \"@/api/sttService\";\nexport default {\n  name: \"ProfessorLesson\",\n  data() {\n    return {\n      isAudioRecording: false,\n      isScreenRecording: false,\n      audioRecorder: null,\n      audioStream: null,\n      audioChunks: [],\n      screenRecorder: null,\n      screenChunks: [],\n      recognition: null,\n      triggerKeywords: [\"보면\", \"보게 되면\", \"이 부분\", \"이걸 보면\", \"코드\", \"화면\", \"여기\", \"이쪽\"],\n      lastTranscript: \"\",\n      displayStream: null\n    };\n  },\n  methods: {\n    async toggleAudioRecording() {\n      if (!this.isAudioRecording) {\n        try {\n          this.audioStream = await navigator.mediaDevices.getUserMedia({\n            audio: true\n          });\n          this.audioRecorder = new MediaRecorder(this.audioStream);\n          this.audioChunks = [];\n          this.audioRecorder.ondataavailable = e => {\n            if (e.data.size > 0) this.audioChunks.push(e.data);\n          };\n          this.audioRecorder.onstop = () => {\n            const blob = new Blob(this.audioChunks, {\n              type: \"audio/webm\"\n            });\n            const url = URL.createObjectURL(blob);\n            const a = document.createElement(\"a\");\n            a.href = url;\n            a.download = \"audio-recording.webm\";\n            a.click();\n            if (this.audioStream) {\n              this.audioStream.getTracks().forEach(track => track.stop());\n              this.audioStream = null;\n            }\n            if (this.displayStream) {\n              this.displayStream.getTracks().forEach(track => track.stop());\n              this.displayStream = null;\n            }\n          };\n          this.displayStream = await navigator.mediaDevices.getDisplayMedia({\n            video: true\n          });\n          this.audioRecorder.start();\n          this.isAudioRecording = true;\n          this.startRecognition();\n        } catch (err) {\n          console.error(\"❌ 오디오 녹음 또는 화면 캡처 권한 실패:\", err);\n        }\n      } else {\n        this.audioRecorder.stop();\n        this.isAudioRecording = false;\n        this.stopRecognition();\n      }\n    },\n    async toggleScreenRecording() {\n      // 선택적: 일반 화면+오디오 녹화 기능 (옵션)\n    },\n    startRecognition() {\n      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;\n      if (!SpeechRecognition) {\n        alert(\"브라우저가 음성 인식을 지원하지 않아요 🙁\");\n        return;\n      }\n      this.recognition = new SpeechRecognition();\n      this.recognition.lang = \"ko-KR\";\n      this.recognition.continuous = true;\n      this.recognition.interimResults = false;\n      this.recognition.onresult = event => {\n        const transcript = event.results[event.results.length - 1][0].transcript;\n        this.lastTranscript = transcript;\n        console.log(\"🎤 음성 인식 결과:\", transcript);\n        const hit = this.triggerKeywords.some(kw => transcript.includes(kw)) || /보.*면|코드|화면|여기|이 부분|이쪽/.test(transcript);\n        if (hit) {\n          this.takeScreenshotAndUpload(transcript);\n        }\n      };\n      this.recognition.onerror = event => {\n        console.error(\"음성 인식 에러:\", event.error);\n      };\n      this.recognition.start();\n    },\n    stopRecognition() {\n      if (this.recognition) {\n        this.recognition.stop();\n        this.recognition = null;\n      }\n    },\n    async takeScreenshotAndUpload(transcript) {\n      try {\n        if (!this.displayStream) return;\n        const track = this.displayStream.getVideoTracks()[0];\n        const imageCapture = new ImageCapture(track);\n        const bitmap = await imageCapture.grabFrame();\n        const canvas = document.createElement(\"canvas\");\n        canvas.width = bitmap.width;\n        canvas.height = bitmap.height;\n        const ctx = canvas.getContext(\"2d\");\n        ctx.drawImage(bitmap, 0, 0);\n        const imageBase64 = canvas.toDataURL(\"image/png\");\n        const now = new Date().toLocaleTimeString();\n        await uploadSnapshot({\n          timestamp: now,\n          transcript,\n          screenshot_base64: imageBase64\n        });\n        console.log(\"✅ 백엔드에 스냅샷 업로드 완료\");\n      } catch (err) {\n        console.error(\"❌ 스크린샷 업로드 실패:\", err);\n      }\n    }\n  }\n};","map":{"version":3,"names":["uploadSnapshot","name","data","isAudioRecording","isScreenRecording","audioRecorder","audioStream","audioChunks","screenRecorder","screenChunks","recognition","triggerKeywords","lastTranscript","displayStream","methods","toggleAudioRecording","navigator","mediaDevices","getUserMedia","audio","MediaRecorder","ondataavailable","e","size","push","onstop","blob","Blob","type","url","URL","createObjectURL","a","document","createElement","href","download","click","getTracks","forEach","track","stop","getDisplayMedia","video","start","startRecognition","err","console","error","stopRecognition","toggleScreenRecording","SpeechRecognition","window","webkitSpeechRecognition","alert","lang","continuous","interimResults","onresult","event","transcript","results","length","log","hit","some","kw","includes","test","takeScreenshotAndUpload","onerror","getVideoTracks","imageCapture","ImageCapture","bitmap","grabFrame","canvas","width","height","ctx","getContext","drawImage","imageBase64","toDataURL","now","Date","toLocaleTimeString","timestamp","screenshot_base64"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\views\\ProfessorLesson.vue"],"sourcesContent":["<template>\r\n  <div class=\"lecture-container text-center mt-5\">\r\n    <h2>🎤 수업 녹화 & 음성 인식</h2>\r\n    <p class=\"text-muted\">녹음 중 키워드가 감지되면 자동으로 화면 캡처와 함께 백엔드에 전송됩니다.</p>\r\n\r\n    <div class=\"btn-group mt-4\">\r\n      <button class=\"btn btn-danger m-2\" @click=\"toggleScreenRecording\">\r\n        {{ isScreenRecording ? \"🛑 화면 녹화 중지\" : \"📹 화면 녹화 시작\" }}\r\n      </button>\r\n\r\n      <button class=\"btn btn-primary m-2\" @click=\"toggleAudioRecording\">\r\n        {{ isAudioRecording ? \"🛑 음성 인식 종료\" : \"🎙️ 음성 인식 시작\" }}\r\n      </button>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { uploadSnapshot } from \"@/api/sttService\";\r\n\r\nexport default {\r\n  name: \"ProfessorLesson\",\r\n  data() {\r\n    return {\r\n      isAudioRecording: false,\r\n      isScreenRecording: false,\r\n      audioRecorder: null,\r\n      audioStream: null,\r\n      audioChunks: [],\r\n      screenRecorder: null,\r\n      screenChunks: [],\r\n      recognition: null,\r\n      triggerKeywords: [\"보면\", \"보게 되면\", \"이 부분\", \"이걸 보면\", \"코드\", \"화면\", \"여기\", \"이쪽\"],\r\n      lastTranscript: \"\",\r\n      displayStream: null,\r\n    };\r\n  },\r\n  methods: {\r\n    async toggleAudioRecording() {\r\n      if (!this.isAudioRecording) {\r\n        try {\r\n          this.audioStream = await navigator.mediaDevices.getUserMedia({ audio: true });\r\n          this.audioRecorder = new MediaRecorder(this.audioStream);\r\n          this.audioChunks = [];\r\n\r\n          this.audioRecorder.ondataavailable = (e) => {\r\n            if (e.data.size > 0) this.audioChunks.push(e.data);\r\n          };\r\n\r\n          this.audioRecorder.onstop = () => {\r\n            const blob = new Blob(this.audioChunks, { type: \"audio/webm\" });\r\n            const url = URL.createObjectURL(blob);\r\n            const a = document.createElement(\"a\");\r\n            a.href = url;\r\n            a.download = \"audio-recording.webm\";\r\n            a.click();\r\n\r\n            if (this.audioStream) {\r\n              this.audioStream.getTracks().forEach((track) => track.stop());\r\n              this.audioStream = null;\r\n            }\r\n\r\n            if (this.displayStream) {\r\n              this.displayStream.getTracks().forEach((track) => track.stop());\r\n              this.displayStream = null;\r\n            }\r\n          };\r\n\r\n          this.displayStream = await navigator.mediaDevices.getDisplayMedia({ video: true });\r\n\r\n          this.audioRecorder.start();\r\n          this.isAudioRecording = true;\r\n\r\n          this.startRecognition();\r\n\r\n        } catch (err) {\r\n          console.error(\"❌ 오디오 녹음 또는 화면 캡처 권한 실패:\", err);\r\n        }\r\n      } else {\r\n        this.audioRecorder.stop();\r\n        this.isAudioRecording = false;\r\n        this.stopRecognition();\r\n      }\r\n    },\r\n\r\n    async toggleScreenRecording() {\r\n      // 선택적: 일반 화면+오디오 녹화 기능 (옵션)\r\n    },\r\n\r\n    startRecognition() {\r\n      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;\r\n      if (!SpeechRecognition) {\r\n        alert(\"브라우저가 음성 인식을 지원하지 않아요 🙁\");\r\n        return;\r\n      }\r\n\r\n      this.recognition = new SpeechRecognition();\r\n      this.recognition.lang = \"ko-KR\";\r\n      this.recognition.continuous = true;\r\n      this.recognition.interimResults = false;\r\n\r\n      this.recognition.onresult = (event) => {\r\n        const transcript = event.results[event.results.length - 1][0].transcript;\r\n        this.lastTranscript = transcript;\r\n        console.log(\"🎤 음성 인식 결과:\", transcript);\r\n\r\n        const hit = this.triggerKeywords.some((kw) => transcript.includes(kw)) ||\r\n                    /보.*면|코드|화면|여기|이 부분|이쪽/.test(transcript);\r\n\r\n        if (hit) {\r\n          this.takeScreenshotAndUpload(transcript);\r\n        }\r\n      };\r\n\r\n      this.recognition.onerror = (event) => {\r\n        console.error(\"음성 인식 에러:\", event.error);\r\n      };\r\n\r\n      this.recognition.start();\r\n    },\r\n\r\n    stopRecognition() {\r\n      if (this.recognition) {\r\n        this.recognition.stop();\r\n        this.recognition = null;\r\n      }\r\n    },\r\n\r\n    async takeScreenshotAndUpload(transcript) {\r\n      try {\r\n        if (!this.displayStream) return;\r\n\r\n        const track = this.displayStream.getVideoTracks()[0];\r\n        const imageCapture = new ImageCapture(track);\r\n        const bitmap = await imageCapture.grabFrame();\r\n\r\n        const canvas = document.createElement(\"canvas\");\r\n        canvas.width = bitmap.width;\r\n        canvas.height = bitmap.height;\r\n        const ctx = canvas.getContext(\"2d\");\r\n        ctx.drawImage(bitmap, 0, 0);\r\n        const imageBase64 = canvas.toDataURL(\"image/png\");\r\n\r\n        const now = new Date().toLocaleTimeString();\r\n\r\n        await uploadSnapshot({\r\n          timestamp: now,\r\n          transcript,\r\n          screenshot_base64: imageBase64,\r\n        });\r\n\r\n        console.log(\"✅ 백엔드에 스냅샷 업로드 완료\");\r\n\r\n      } catch (err) {\r\n        console.error(\"❌ 스크린샷 업로드 실패:\", err);\r\n      }\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.lecture-container {\r\n  max-width: 900px;\r\n  margin: auto;\r\n  padding: 30px;\r\n}\r\n</style>\r\n"],"mappings":";;;;;;;AAkBA,SAASA,cAAa,QAAS,kBAAkB;AAEjD,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,gBAAgB,EAAE,KAAK;MACvBC,iBAAiB,EAAE,KAAK;MACxBC,aAAa,EAAE,IAAI;MACnBC,WAAW,EAAE,IAAI;MACjBC,WAAW,EAAE,EAAE;MACfC,cAAc,EAAE,IAAI;MACpBC,YAAY,EAAE,EAAE;MAChBC,WAAW,EAAE,IAAI;MACjBC,eAAe,EAAE,CAAC,IAAI,EAAE,OAAO,EAAE,MAAM,EAAE,OAAO,EAAE,IAAI,EAAE,IAAI,EAAE,IAAI,EAAE,IAAI,CAAC;MACzEC,cAAc,EAAE,EAAE;MAClBC,aAAa,EAAE;IACjB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,oBAAoBA,CAAA,EAAG;MAC3B,IAAI,CAAC,IAAI,CAACZ,gBAAgB,EAAE;QAC1B,IAAI;UACF,IAAI,CAACG,WAAU,GAAI,MAAMU,SAAS,CAACC,YAAY,CAACC,YAAY,CAAC;YAAEC,KAAK,EAAE;UAAK,CAAC,CAAC;UAC7E,IAAI,CAACd,aAAY,GAAI,IAAIe,aAAa,CAAC,IAAI,CAACd,WAAW,CAAC;UACxD,IAAI,CAACC,WAAU,GAAI,EAAE;UAErB,IAAI,CAACF,aAAa,CAACgB,eAAc,GAAKC,CAAC,IAAK;YAC1C