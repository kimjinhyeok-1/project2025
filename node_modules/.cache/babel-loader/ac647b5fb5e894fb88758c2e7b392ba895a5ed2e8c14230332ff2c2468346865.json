{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/web.url-search-params.delete.js\";\nimport \"core-js/modules/web.url-search-params.has.js\";\nimport \"core-js/modules/web.url-search-params.size.js\";\nexport default {\n  name: \"ProfessorView\",\n  methods: {\n    async startScreenRecording() {\n      try {\n        const stream = await navigator.mediaDevices.getDisplayMedia({\n          video: true,\n          audio: true\n        });\n        const recorder = new MediaRecorder(stream);\n        const chunks = [];\n        recorder.ondataavailable = e => {\n          if (e.data.size > 0) chunks.push(e.data);\n        };\n        recorder.onstop = () => {\n          const blob = new Blob(chunks, {\n            type: \"video/webm\"\n          });\n          const url = URL.createObjectURL(blob);\n          const a = document.createElement(\"a\");\n          a.href = url;\n          a.download = \"screen-recording.webm\";\n          a.click();\n          console.log(\"🟢 녹화 파일 저장 완료\");\n        };\n        recorder.start();\n        console.log(\"🔴 화면 녹화 시작됨\");\n        stream.getVideoTracks()[0].addEventListener(\"ended\", () => {\n          recorder.stop();\n          console.log(\"🛑 화면 공유 종료 감지 → 녹화 종료\");\n        });\n      } catch (err) {\n        console.error(\"❌ 화면 녹화 실패:\", err);\n      }\n    },\n    async startAudioRecording() {\n      try {\n        const stream = await navigator.mediaDevices.getUserMedia({\n          audio: true\n        });\n        const recorder = new MediaRecorder(stream);\n        const chunks = [];\n        recorder.ondataavailable = e => {\n          if (e.data.size > 0) chunks.push(e.data);\n        };\n        recorder.onstop = () => {\n          const blob = new Blob(chunks, {\n            type: \"audio/webm\"\n          });\n          const url = URL.createObjectURL(blob);\n          const a = document.createElement(\"a\");\n          a.href = url;\n          a.download = \"audio-recording.webm\";\n          a.click();\n          console.log(\"🎧 오디오 파일 저장 완료\");\n        };\n        recorder.start();\n        console.log(\"🎙️ 오디오 녹음 시작됨\");\n\n        // 마이크가 꺼지면 자동으로 녹음 종료\n        stream.getAudioTracks()[0].addEventListener(\"ended\", () => {\n          recorder.stop();\n          console.log(\"🛑 마이크 사용 종료 감지 → 녹음 종료\");\n        });\n      } catch (err) {\n        console.error(\"❌ 오디오 녹음 실패:\", err);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","methods","startScreenRecording","stream","navigator","mediaDevices","getDisplayMedia","video","audio","recorder","MediaRecorder","chunks","ondataavailable","e","data","size","push","onstop","blob","Blob","type","url","URL","createObjectURL","a","document","createElement","href","download","click","console","log","start","getVideoTracks","addEventListener","stop","err","error","startAudioRecording","getUserMedia","getAudioTracks"],"sources":["C:\\Users\\user\\test\\src\\views\\ProfessorView.vue"],"sourcesContent":["<template>\r\n  <div class=\"text-center mt-5\">\r\n    <h2>Professor Dashboard</h2>\r\n    <p>Welcome, Professor! Here you can manage your classes and students.</p>\r\n\r\n    <!-- 화면 녹화 버튼 -->\r\n    <button class=\"btn btn-danger m-2\" @click=\"startScreenRecording\">\r\n      📹 화면 녹화 시작\r\n    </button>\r\n\r\n    <!-- 오디오 녹음 버튼 -->\r\n    <button class=\"btn btn-primary m-2\" @click=\"startAudioRecording\">\r\n      🎙️ 음성 녹음 시작\r\n    </button>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ProfessorView\",\r\n\r\n  methods: {\r\n    async startScreenRecording() {\r\n      try {\r\n        const stream = await navigator.mediaDevices.getDisplayMedia({ video: true, audio: true });\r\n        const recorder = new MediaRecorder(stream);\r\n        const chunks = [];\r\n\r\n        recorder.ondataavailable = (e) => {\r\n          if (e.data.size > 0) chunks.push(e.data);\r\n        };\r\n\r\n        recorder.onstop = () => {\r\n          const blob = new Blob(chunks, { type: \"video/webm\" });\r\n          const url = URL.createObjectURL(blob);\r\n          const a = document.createElement(\"a\");\r\n          a.href = url;\r\n          a.download = \"screen-recording.webm\";\r\n          a.click();\r\n          console.log(\"🟢 녹화 파일 저장 완료\");\r\n        };\r\n\r\n        recorder.start();\r\n        console.log(\"🔴 화면 녹화 시작됨\");\r\n\r\n        stream.getVideoTracks()[0].addEventListener(\"ended\", () => {\r\n          recorder.stop();\r\n          console.log(\"🛑 화면 공유 종료 감지 → 녹화 종료\");\r\n        });\r\n      } catch (err) {\r\n        console.error(\"❌ 화면 녹화 실패:\", err);\r\n      }\r\n    },\r\n\r\n    async startAudioRecording() {\r\n      try {\r\n        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });\r\n        const recorder = new MediaRecorder(stream);\r\n        const chunks = [];\r\n\r\n        recorder.ondataavailable = (e) => {\r\n          if (e.data.size > 0) chunks.push(e.data);\r\n        };\r\n\r\n        recorder.onstop = () => {\r\n          const blob = new Blob(chunks, { type: \"audio/webm\" });\r\n          const url = URL.createObjectURL(blob);\r\n          const a = document.createElement(\"a\");\r\n          a.href = url;\r\n          a.download = \"audio-recording.webm\";\r\n          a.click();\r\n          console.log(\"🎧 오디오 파일 저장 완료\");\r\n        };\r\n\r\n        recorder.start();\r\n        console.log(\"🎙️ 오디오 녹음 시작됨\");\r\n\r\n        // 마이크가 꺼지면 자동으로 녹음 종료\r\n        stream.getAudioTracks()[0].addEventListener(\"ended\", () => {\r\n          recorder.stop();\r\n          console.log(\"🛑 마이크 사용 종료 감지 → 녹음 종료\");\r\n        });\r\n      } catch (err) {\r\n        console.error(\"❌ 오디오 녹음 실패:\", err);\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n"],"mappings":";;;;AAkBA,eAAe;EACbA,IAAI,EAAE,eAAe;EAErBC,OAAO,EAAE;IACP,MAAMC,oBAAoBA,CAAA,EAAG;MAC3B,IAAI;QACF,MAAMC,MAAK,GAAI,MAAMC,SAAS,CAACC,YAAY,CAACC,eAAe,CAAC;UAAEC,KAAK,EAAE,IAAI;UAAEC,KAAK,E