{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, onMounted } from 'vue';\nimport { useRouter } from 'vue-router';\nexport default {\n  name: 'NavbarComponent',\n  setup() {\n    const isLoggedIn = ref(false);\n    const router = useRouter();\n    const checkLogin = () => {\n      isLoggedIn.value = !!localStorage.getItem('user');\n    };\n    const logout = () => {\n      localStorage.removeItem('user');\n      isLoggedIn.value = false;\n      router.push('/');\n    };\n    onMounted(() => {\n      checkLogin();\n    });\n    return {\n      isLoggedIn,\n      logout\n    };\n  }\n};","map":{"version":3,"names":["ref","onMounted","useRouter","name","setup","isLoggedIn","router","checkLogin","value","localStorage","getItem","logout","removeItem","push"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\components\\NavbarComponent.vue"],"sourcesContent":["<template>\r\n  <nav class=\"navbar navbar-expand-lg bg-primary\">\r\n    <div class=\"container-fluid\">\r\n      <!-- 로고: 클릭 시 이동하지 않도록 router-link 제거 -->\r\n      <span class=\"navbar-brand text-white fw-bold\">Koreatech</span>\r\n\r\n      <button\r\n        class=\"navbar-toggler\"\r\n        type=\"button\"\r\n        data-bs-toggle=\"collapse\"\r\n        data-bs-target=\"#navbarSupportedContent\"\r\n        aria-controls=\"navbarSupportedContent\"\r\n        aria-expanded=\"false\"\r\n        aria-label=\"Toggle navigation\"\r\n      >\r\n        <span class=\"navbar-toggler-icon\"></span>\r\n      </button>\r\n\r\n      <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\r\n        <ul class=\"navbar-nav me-auto mb-2 mb-lg-0\">\r\n          <!-- 필요 시 다른 메뉴 유지 -->\r\n          <li class=\"nav-item\">\r\n            <router-link class=\"nav-link text-white\" to=\"/student\">Student</router-link>\r\n          </li>\r\n          <li class=\"nav-item\">\r\n            <router-link class=\"nav-link text-white\" to=\"/professor\">Professor</router-link>\r\n          </li>\r\n        </ul>\r\n\r\n        <!-- 로그아웃 버튼 (로그인 상태일 때만 표시) -->\r\n        <div v-if=\"isLoggedIn\" class=\"d-flex\">\r\n          <button class=\"btn btn-outline-light\" @click=\"logout\">Logout</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </nav>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nexport default {\r\n  name: 'NavbarComponent',\r\n  setup() {\r\n    const isLoggedIn = ref(false)\r\n    const router = useRouter()\r\n\r\n    const checkLogin = () => {\r\n      isLoggedIn.value = !!localStorage.getItem('user')\r\n    }\r\n\r\n    const logout = () => {\r\n      localStorage.removeItem('user')\r\n      isLoggedIn.value = false\r\n      router.push('/')\r\n    }\r\n\r\n    onMounted(() => {\r\n      checkLogin()\r\n    })\r\n\r\n    return {\r\n      isLoggedIn,\r\n      logout,\r\n    }\r\n  },\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.navbar {\r\n  box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);\r\n}\r\n</style>\r\n"],"mappings":";AAuCA,SAASA,GAAG,EAAEC,SAAQ,QAAS,KAAI;AACnC,SAASC,SAAQ,QAAS,YAAW;AAErC,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,KAAKA,CAAA,EAAG;IACN,MAAMC,UAAS,GAAIL,GAAG,CAAC,KAAK;IAC5B,MAAMM,MAAK,GAAIJ,SAAS,CAAC;IAEzB,MAAMK,UAAS,GAAIA,CAAA,KAAM;MACvBF,UAAU,CAACG,KAAI,GAAI,CAAC,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM;IAClD;IAEA,MAAMC,MAAK,GAAIA,CAAA,KAAM;MACnBF,YAAY,CAACG,UAAU,CAAC,MAAM;MAC9BP,UAAU,CAACG,KAAI,GAAI,KAAI;MACvBF,MAAM,CAACO,IAAI,CAAC,GAAG;IACjB;IAEAZ,SAAS,CAAC,MAAM;MACdM,UAAU,CAAC;IACb,CAAC;IAED,OAAO;MACLF,UAAU;MACVM;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}