{"ast":null,"code":"import { ref } from \"vue\";\nimport ChatComponent from \"@/components/ChatComponent.vue\";\nexport default {\n  name: \"StudentView\",\n  components: {\n    ChatComponent\n  },\n  setup() {\n    const showChat = ref(false); // 채팅 버튼 상태 관리\n\n    return {\n      showChat\n    };\n  }\n};","map":{"version":3,"names":["ref","ChatComponent","name","components","setup","showChat"],"sources":["C:\\Users\\user\\test\\src\\views\\StudentView.vue"],"sourcesContent":["<template>\r\n  <div class=\"container\">\r\n    <h2>Student Dashboard</h2>\r\n    <p>Welcome, Student! Here you can access your courses and grades.</p>\r\n\r\n    <!-- 채팅 버튼 -->\r\n    <button @click=\"showChat = !showChat\" class=\"btn btn-primary mt-3\">\r\n      {{ showChat ? \"Close Chat\" : \"Open Chat\" }}\r\n    </button>\r\n\r\n    <!-- 채팅 UI -->\r\n    <ChatComponent v-if=\"showChat\" />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref } from \"vue\";\r\nimport ChatComponent from \"@/components/ChatComponent.vue\";\r\n\r\nexport default {\r\n  name: \"StudentView\",\r\n  components: {\r\n    ChatComponent,\r\n  },\r\n  setup() {\r\n    const showChat = ref(false); // 채팅 버튼 상태 관리\r\n\r\n    return { showChat };\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.container {\r\n  text-align: center;\r\n  margin-top: 20px;\r\n}\r\n</style>\r\n"],"mappings":"AAgBA,SAASA,GAAE,QAAS,KAAK;AACzB,OAAOC,aAAY,MAAO,gCAAgC;AAE1D,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,UAAU,EAAE;IACVF;EACF,CAAC;EACDG,KAAKA,CAAA,EAAG;IACN,MAAMC,QAAO,GAAIL,GAAG,CAAC,KAAK,CAAC,EAAE;;IAE7B,OAAO;MAAEK;IAAS,CAAC;EACrB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}