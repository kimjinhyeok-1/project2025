{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref } from 'vue';\nimport { useRouter } from 'vue-router';\nexport default {\n  name: 'HomeView',\n  setup() {\n    const userId = ref('');\n    const password = ref('');\n    const errorMessage = ref('');\n    const router = useRouter();\n    const users = [{\n      id: 'prof001',\n      password: '1234',\n      role: 'teacher'\n    }, {\n      id: 'stu001',\n      password: '5678',\n      role: 'student'\n    }];\n    const handleLogin = () => {\n      const foundUser = users.find(user => user.id === userId.value && user.password === password.value);\n      if (foundUser) {\n        if (foundUser.role === 'teacher') {\n          router.push('/professor');\n        } else if (foundUser.role === 'student') {\n          router.push('/student');\n        }\n      } else {\n        errorMessage.value = '아이디 또는 비밀번호가 올바르지 않습니다.';\n      }\n    };\n    return {\n      userId,\n      password,\n      handleLogin,\n      errorMessage\n    };\n  }\n};","map":{"version":3,"names":["ref","useRouter","name","setup","userId","password","errorMessage","router","users","id","role","handleLogin","foundUser","find","user","value","push"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\views\\HomeView.vue"],"sourcesContent":["<!-- src/views/HomeView.vue -->\r\n<template>\r\n  <div class=\"bg-gradient-primary min-vh-100 d-flex justify-content-center align-items-center\">\r\n    <div class=\"card shadow p-5\" style=\"width: 400px; border-radius: 1rem;\">\r\n      <!-- 상단 로고 + 제목 -->\r\n      <div class=\"text-center mb-4\">\r\n        <img src=\"/kut_logo.gif\" alt=\"Logo\" class=\"logo-gif mb-2\" />\r\n        <h1 class=\"mb-1\">KOREATECH</h1>\r\n        <p class=\"text-muted\">온라인 교육</p>\r\n      </div>\r\n\r\n      <!-- 로그인 폼 -->\r\n      <form @submit.prevent=\"handleLogin\">\r\n        <div class=\"form-group mb-3\">\r\n          <input\r\n            v-model=\"userId\"\r\n            type=\"text\"\r\n            class=\"form-control rounded-pill\"\r\n            placeholder=\"아이디\"\r\n            required\r\n          />\r\n        </div>\r\n        <div class=\"form-group mb-3\">\r\n          <input\r\n            v-model=\"password\"\r\n            type=\"password\"\r\n            class=\"form-control rounded-pill\"\r\n            placeholder=\"비밀번호\"\r\n            required\r\n          />\r\n        </div>\r\n        <button type=\"submit\" class=\"btn btn-primary w-100 rounded-pill\">로그인</button>\r\n      </form>\r\n\r\n      <p v-if=\"errorMessage\" class=\"text-danger text-center mt-3\">{{ errorMessage }}</p>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nexport default {\r\n  name: 'HomeView',\r\n  setup() {\r\n    const userId = ref('')\r\n    const password = ref('')\r\n    const errorMessage = ref('')\r\n    const router = useRouter()\r\n\r\n    const users = [\r\n      { id: 'prof001', password: '1234', role: 'teacher' },\r\n      { id: 'stu001', password: '5678', role: 'student' },\r\n    ]\r\n\r\n    const handleLogin = () => {\r\n      const foundUser = users.find(\r\n        (user) => user.id === userId.value && user.password === password.value\r\n      )\r\n\r\n      if (foundUser) {\r\n        if (foundUser.role === 'teacher') {\r\n          router.push('/professor')\r\n        } else if (foundUser.role === 'student') {\r\n          router.push('/student')\r\n        }\r\n      } else {\r\n        errorMessage.value = '아이디 또는 비밀번호가 올바르지 않습니다.'\r\n      }\r\n    }\r\n\r\n    return {\r\n      userId,\r\n      password,\r\n      handleLogin,\r\n      errorMessage\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.bg-gradient-primary {\r\n  background: linear-gradient(to bottom right, #4e73df, #224abe);\r\n}\r\n\r\n.logo-gif {\r\n  width: 60px;\r\n  height: auto;\r\n  border-radius: 8px;\r\n}\r\n\r\n.mb-1 {\r\n  font-family: 'Do Hyeon', sans-serif;\r\n  font-size: 2.0rem;\r\n  font-weight: 700;\r\n  color: #1a1a1a;\r\n}\r\n\r\n.text-muted {\r\n  font-family: 'Do Hyeon', sans-serif;\r\n  font-size: 1.0rem;\r\n  font-weight: 600;\r\n  color: #555;\r\n}\r\n</style>\r\n"],"mappings":";AAwCA,SAASA,GAAE,QAAS,KAAI;AACxB,SAASC,SAAQ,QAAS,YAAW;AAErC,eAAe;EACbC,IAAI,EAAE,UAAU;EAChBC,KAAKA,CAAA,EAAG;IACN,MAAMC,MAAK,GAAIJ,GAAG,CAAC,EAAE;IACrB,MAAMK,QAAO,GAAIL,GAAG,CAAC,EAAE;IACvB,MAAMM,YAAW,GAAIN,GAAG,CAAC,EAAE;IAC3B,MAAMO,MAAK,GAAIN,SAAS,CAAC;IAEzB,MAAMO,KAAI,GAAI,CACZ;MAAEC,EAAE,EAAE,SAAS;MAAEJ,QAAQ,EAAE,MAAM;MAAEK,IAAI,EAAE;IAAU,CAAC,EACpD;MAAED,EAAE,EAAE,QAAQ;MAAEJ,QAAQ,EAAE,MAAM;MAAEK,IAAI,EAAE;IAAU,CAAC,CACrD;IAEA,MAAMC,WAAU,GAAIA,CAAA,KAAM;MACxB,MAAMC,SAAQ,GAAIJ,KAAK,CAACK,IAAI,CACzBC,IAAI,IAAKA,IAAI,CAACL,EAAC,KAAML,MAAM,CAACW,KAAI,IAAKD,IAAI,CAACT,QAAO,KAAMA,QAAQ,CAACU,KACnE;MAEA,IAAIH,SAAS,EAAE;QACb,IAAIA,SAAS,CAACF,IAAG,KAAM,SAAS,EAAE;UAChCH,MAAM,CAACS,IAAI,CAAC,YAAY;QAC1B,OAAO,IAAIJ,SAAS,CAACF,IAAG,KAAM,SAAS,EAAE;UACvCH,MAAM,CAACS,IAAI,CAAC,UAAU;QACxB;MACF,OAAO;QACLV,YAAY,CAACS,KAAI,GAAI,yBAAwB;MAC/C;IACF;IAEA,OAAO;MACLX,MAAM;MACNC,QAAQ;MACRM,WAAW;MACXL;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}