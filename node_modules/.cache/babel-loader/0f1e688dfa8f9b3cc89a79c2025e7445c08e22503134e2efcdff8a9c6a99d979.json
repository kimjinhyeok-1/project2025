{"ast":null,"code":"import { ref, computed, onMounted } from 'vue';\nexport default {\n  name: \"NavbarComponent\",\n  setup() {\n    const userRole = ref(localStorage.getItem('userRole') || '');\n    const roleLabel = computed(() => {\n      if (userRole.value === 'teacher') return '교수자';\n      if (userRole.value === 'student') return '학생';\n      return '';\n    });\n    const updateUserRole = () => {\n      userRole.value = localStorage.getItem('userRole') || '';\n    };\n    onMounted(() => {\n      // 페이지 새로고침 없이도 반영되도록 이벤트 리스너 등록\n      window.addEventListener('storage', updateUserRole);\n    });\n    return {\n      userRole,\n      roleLabel\n    };\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","name","setup","userRole","localStorage","getItem","roleLabel","value","updateUserRole","window","addEventListener"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\components\\NavbarComponent.vue"],"sourcesContent":["<template>\r\n  <nav class=\"navbar navbar-expand-lg bg-primary\">\r\n    <div class=\"container-fluid\">\r\n      <!-- 로고 -->\r\n      <span class=\"navbar-brand text-white fw-bold\">Koreatech</span>\r\n\r\n      <button\r\n        class=\"navbar-toggler\"\r\n        type=\"button\"\r\n        data-bs-toggle=\"collapse\"\r\n        data-bs-target=\"#navbarSupportedContent\"\r\n        aria-controls=\"navbarSupportedContent\"\r\n        aria-expanded=\"false\"\r\n        aria-label=\"Toggle navigation\"\r\n      >\r\n        <span class=\"navbar-toggler-icon\"></span>\r\n      </button>\r\n\r\n      <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\r\n        <ul class=\"navbar-nav me-auto mb-2 mb-lg-0\">\r\n          <li class=\"nav-item\">\r\n            <router-link class=\"nav-link text-white\" to=\"/student\">Student</router-link>\r\n          </li>\r\n          <li class=\"nav-item\">\r\n            <router-link class=\"nav-link text-white\" to=\"/professor\">Professor</router-link>\r\n          </li>\r\n        </ul>\r\n\r\n        <!-- 사용자 프로필 -->\r\n        <div class=\"d-flex align-items-center text-white\">\r\n          <span v-if=\"userRole\" class=\"fw-semibold\">👤 {{ roleLabel }}</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </nav>\r\n</template>\r\n\r\n<script>\r\nimport { ref, computed, onMounted } from 'vue'\r\n\r\nexport default {\r\n  name: \"NavbarComponent\",\r\n  setup() {\r\n    const userRole = ref(localStorage.getItem('userRole') || '')\r\n\r\n    const roleLabel = computed(() => {\r\n      if (userRole.value === 'teacher') return '교수자'\r\n      if (userRole.value === 'student') return '학생'\r\n      return ''\r\n    })\r\n\r\n    const updateUserRole = () => {\r\n      userRole.value = localStorage.getItem('userRole') || ''\r\n    }\r\n\r\n    onMounted(() => {\r\n      // 페이지 새로고침 없이도 반영되도록 이벤트 리스너 등록\r\n      window.addEventListener('storage', updateUserRole)\r\n    })\r\n\r\n    return {\r\n      userRole,\r\n      roleLabel\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.navbar {\r\n  box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);\r\n}\r\n</style>\r\n"],"mappings":"AAsCA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAQ,QAAS,KAAI;AAE7C,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,KAAKA,CAAA,EAAG;IACN,MAAMC,QAAO,GAAIL,GAAG,CAACM,YAAY,CAACC,OAAO,CAAC,UAAU,KAAK,EAAE;IAE3D,MAAMC,SAAQ,GAAIP,QAAQ,CAAC,MAAM;MAC/B,IAAII,QAAQ,CAACI,KAAI,KAAM,SAAS,EAAE,OAAO,KAAI;MAC7C,IAAIJ,QAAQ,CAACI,KAAI,KAAM,SAAS,EAAE,OAAO,IAAG;MAC5C,OAAO,EAAC;IACV,CAAC;IAED,MAAMC,cAAa,GAAIA,CAAA,KAAM;MAC3BL,QAAQ,CAACI,KAAI,GAAIH,YAAY,CAACC,OAAO,CAAC,UAAU,KAAK,EAAC;IACxD;IAEAL,SAAS,CAAC,MAAM;MACd;MACAS,MAAM,CAACC,gBAAgB,CAAC,SAAS,EAAEF,cAAc;IACnD,CAAC;IAED,OAAO;MACLL,QAAQ;MACRG;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}