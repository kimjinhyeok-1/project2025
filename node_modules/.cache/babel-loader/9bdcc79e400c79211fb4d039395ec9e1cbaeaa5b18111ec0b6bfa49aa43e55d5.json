{"ast":null,"code":"import { useRoute } from 'vue-router';\nimport { computed } from 'vue';\nimport NavbarComponent from './components/NavbarComponent.vue';\nexport default {\n  components: {\n    NavbarComponent\n  },\n  setup() {\n    const route = useRoute();\n    const isHome = computed(() => route?.path === '/'); // ✅ 안전하게 체크\n    return {\n      isHome\n    };\n  }\n};","map":{"version":3,"names":["useRoute","computed","NavbarComponent","components","setup","route","isHome","path"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\App.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <!-- 현재 경로가 '/'가 아닐 때만 네비게이션 바 표시 -->\r\n    <NavbarComponent v-if=\"!isHome\" />\r\n\r\n    <!-- 라우터 뷰는 항상 표시 -->\r\n    <div>\r\n      <router-view></router-view>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { useRoute } from 'vue-router'\r\nimport { computed } from 'vue'\r\nimport NavbarComponent from './components/NavbarComponent.vue'\r\n\r\nexport default {\r\n  components: {\r\n    NavbarComponent,\r\n  },\r\n  setup() {\r\n    const route = useRoute()\r\n    const isHome = computed(() => route?.path === '/') // ✅ 안전하게 체크\r\n    return {\r\n      isHome,\r\n    }\r\n  },\r\n}\r\n</script>\r\n"],"mappings":"AAaA,SAASA,QAAO,QAAS,YAAW;AACpC,SAASC,QAAO,QAAS,KAAI;AAC7B,OAAOC,eAAc,MAAO,kCAAiC;AAE7D,eAAe;EACbC,UAAU,EAAE;IACVD;EACF,CAAC;EACDE,KAAKA,CAAA,EAAG;IACN,MAAMC,KAAI,GAAIL,QAAQ,CAAC;IACvB,MAAMM,MAAK,GAAIL,QAAQ,CAAC,MAAMI,KAAK,EAAEE,IAAG,KAAM,GAAG,GAAE;IACnD,OAAO;MACLD;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}