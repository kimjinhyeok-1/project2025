{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/web.url-search-params.delete.js\";\nimport \"core-js/modules/web.url-search-params.has.js\";\nimport \"core-js/modules/web.url-search-params.size.js\";\nexport default {\n  name: \"ProfessorLesson\",\n  data() {\n    return {\n      // 오디오 녹음 상태\n      isAudioRecording: false,\n      audioRecorder: null,\n      audioStream: null,\n      audioChunks: [],\n      // 화면 녹화 상태\n      isScreenRecording: false,\n      screenRecorder: null,\n      screenChunks: []\n    };\n  },\n  methods: {\n    // 🎙️ 오디오 녹음 토글\n    async toggleAudioRecording() {\n      if (!this.isAudioRecording) {\n        try {\n          this.audioStream = await navigator.mediaDevices.getUserMedia({\n            audio: true\n          });\n          this.audioRecorder = new MediaRecorder(this.audioStream);\n          this.audioChunks = [];\n          this.audioRecorder.ondataavailable = e => {\n            if (e.data.size > 0) this.audioChunks.push(e.data);\n          };\n          this.audioRecorder.onstop = () => {\n            const blob = new Blob(this.audioChunks, {\n              type: \"audio/webm\"\n            });\n            const url = URL.createObjectURL(blob);\n            const a = document.createElement(\"a\");\n            a.href = url;\n            a.download = \"audio-recording.webm\";\n            a.click();\n            if (this.audioStream) {\n              this.audioStream.getTracks().forEach(track => track.stop());\n              this.audioStream = null;\n            }\n          };\n          this.audioRecorder.start();\n          this.isAudioRecording = true;\n          console.log(\"🎙️ 오디오 녹음 시작됨\");\n          this.audioStream.getAudioTracks()[0].addEventListener(\"ended\", () => {\n            if (this.isAudioRecording) {\n              this.audioRecorder.stop();\n              this.isAudioRecording = false;\n              console.log(\"🛑 마이크 꺼짐 → 녹음 종료\");\n            }\n          });\n        } catch (err) {\n          console.error(\"❌ 오디오 녹음 실패:\", err);\n        }\n      } else {\n        this.audioRecorder.stop();\n        this.isAudioRecording = false;\n        console.log(\"🛑 오디오 녹음 수동 중지됨\");\n      }\n    },\n    // 📹 화면 + 마이크 오디오 녹화 토글\n    async toggleScreenRecording() {\n      if (!this.isScreenRecording) {\n        try {\n          const displayStream = await navigator.mediaDevices.getDisplayMedia({\n            video: true,\n            audio: true // 시스템 오디오 (브라우저에 따라 다름)\n          });\n          const micStream = await navigator.mediaDevices.getUserMedia({\n            audio: true\n          }); // 마이크 오디오\n\n          const combinedStream = new MediaStream([...displayStream.getVideoTracks(), ...micStream.getAudioTracks()]);\n          this.screenRecorder = new MediaRecorder(combinedStream);\n          this.screenChunks = [];\n          this.screenRecorder.ondataavailable = e => {\n            if (e.data.size > 0) this.screenChunks.push(e.data);\n          };\n          this.screenRecorder.onstop = () => {\n            const blob = new Blob(this.screenChunks, {\n              type: \"video/webm\"\n            });\n            const url = URL.createObjectURL(blob);\n            const a = document.createElement(\"a\");\n            a.href = url;\n            a.download = \"screen-recording-with-audio.webm\";\n            a.click();\n            displayStream.getTracks().forEach(track => track.stop());\n            micStream.getTracks().forEach(track => track.stop());\n          };\n          this.screenRecorder.start();\n          this.isScreenRecording = true;\n          console.log(\"🔴 화면+마이크 녹화 시작됨\");\n          displayStream.getVideoTracks()[0].addEventListener(\"ended\", () => {\n            if (this.isScreenRecording) {\n              this.screenRecorder.stop();\n              this.isScreenRecording = false;\n              console.log(\"🛑 화면 공유 종료 감지 → 녹화 종료\");\n            }\n          });\n        } catch (err) {\n          console.error(\"❌ 화면+오디오 녹화 실패:\", err);\n        }\n      } else {\n        this.screenRecorder.stop();\n        this.isScreenRecording = false;\n        console.log(\"🛑 화면+마이크 녹화 수동 중지됨\");\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","isAudioRecording","audioRecorder","audioStream","audioChunks","isScreenRecording","screenRecorder","screenChunks","methods","toggleAudioRecording","navigator","mediaDevices","getUserMedia","audio","MediaRecorder","ondataavailable","e","size","push","onstop","blob","Blob","type","url","URL","createObjectURL","a","document","createElement","href","download","click","getTracks","forEach","track","stop","start","console","log","getAudioTracks","addEventListener","err","error","toggleScreenRecording","displayStream","getDisplayMedia","video","micStream","combinedStream","MediaStream","getVideoTracks"],"sources":["C:\\Users\\user\\test\\src\\views\\ProfessorLesson.vue"],"sourcesContent":["<template>\r\n    <div class=\"text-center mt-5\">\r\n      <h2>🎥 수업 녹화 & 음성 녹음</h2>\r\n      <p class=\"text-muted\">아래 버튼으로 수업을 시작하거나 종료하세요.</p>\r\n  \r\n      <!-- 화면 녹화 토글 버튼 -->\r\n      <button class=\"btn btn-danger m-2\" @click=\"toggleScreenRecording\">\r\n        {{ isScreenRecording ? \"🛑 화면 녹화 중지\" : \"📹 화면 녹화 시작\" }}\r\n      </button>\r\n  \r\n      <!-- 오디오 녹음 토글 버튼 -->\r\n      <button class=\"btn btn-primary m-2\" @click=\"toggleAudioRecording\">\r\n        {{ isAudioRecording ? \"🛑 녹음 중지\" : \"🎙️ 음성 녹음 시작\" }}\r\n      </button>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  export default {\r\n    name: \"ProfessorLesson\",\r\n    data() {\r\n      return {\r\n        // 오디오 녹음 상태\r\n        isAudioRecording: false,\r\n        audioRecorder: null,\r\n        audioStream: null,\r\n        audioChunks: [],\r\n  \r\n        // 화면 녹화 상태\r\n        isScreenRecording: false,\r\n        screenRecorder: null,\r\n        screenChunks: [],\r\n      };\r\n    },\r\n    methods: {\r\n      // 🎙️ 오디오 녹음 토글\r\n      async toggleAudioRecording() {\r\n        if (!this.isAudioRecording) {\r\n          try {\r\n            this.audioStream = await navigator.mediaDevices.getUserMedia({ audio: true });\r\n            this.audioRecorder = new MediaRecorder(this.audioStream);\r\n            this.audioChunks = [];\r\n  \r\n            this.audioRecorder.ondataavailable = (e) => {\r\n              if (e.data.size > 0) this.audioChunks.push(e.data);\r\n            };\r\n  \r\n            this.audioRecorder.onstop = () => {\r\n              const blob = new Blob(this.audioChunks, { type: \"audio/webm\" });\r\n              const url = URL.createObjectURL(blob);\r\n              const a = document.createElement(\"a\");\r\n              a.href = url;\r\n              a.download = \"audio-recording.webm\";\r\n              a.click();\r\n  \r\n              if (this.audioStream) {\r\n                this.audioStream.getTracks().forEach((track) => track.stop());\r\n                this.audioStream = null;\r\n              }\r\n            };\r\n  \r\n            this.audioRecorder.start();\r\n            this.isAudioRecording = true;\r\n            console.log(\"🎙️ 오디오 녹음 시작됨\");\r\n  \r\n            this.audioStream.getAudioTracks()[0].addEventListener(\"ended\", () => {\r\n              if (this.isAudioRecording) {\r\n                this.audioRecorder.stop();\r\n                this.isAudioRecording = false;\r\n                console.log(\"🛑 마이크 꺼짐 → 녹음 종료\");\r\n              }\r\n            });\r\n          } catch (err) {\r\n            console.error(\"❌ 오디오 녹음 실패:\", err);\r\n          }\r\n        } else {\r\n          this.audioRecorder.stop();\r\n          this.isAudioRecording = false;\r\n          console.log(\"🛑 오디오 녹음 수동 중지됨\");\r\n        }\r\n      },\r\n  \r\n      // 📹 화면 + 마이크 오디오 녹화 토글\r\n      async toggleScreenRecording() {\r\n        if (!this.isScreenRecording) {\r\n          try {\r\n            const displayStream = await navigator.mediaDevices.getDisplayMedia({\r\n              video: true,\r\n              audio: true, // 시스템 오디오 (브라우저에 따라 다름)\r\n            });\r\n  \r\n            const micStream = await navigator.mediaDevices.getUserMedia({ audio: true }); // 마이크 오디오\r\n  \r\n            const combinedStream = new MediaStream([\r\n              ...displayStream.getVideoTracks(),\r\n              ...micStream.getAudioTracks(),\r\n            ]);\r\n  \r\n            this.screenRecorder = new MediaRecorder(combinedStream);\r\n            this.screenChunks = [];\r\n  \r\n            this.screenRecorder.ondataavailable = (e) => {\r\n              if (e.data.size > 0) this.screenChunks.push(e.data);\r\n            };\r\n  \r\n            this.screenRecorder.onstop = () => {\r\n              const blob = new Blob(this.screenChunks, { type: \"video/webm\" });\r\n              const url = URL.createObjectURL(blob);\r\n              const a = document.createElement(\"a\");\r\n              a.href = url;\r\n              a.download = \"screen-recording-with-audio.webm\";\r\n              a.click();\r\n  \r\n              displayStream.getTracks().forEach((track) => track.stop());\r\n              micStream.getTracks().forEach((track) => track.stop());\r\n            };\r\n  \r\n            this.screenRecorder.start();\r\n            this.isScreenRecording = true;\r\n            console.log(\"🔴 화면+마이크 녹화 시작됨\");\r\n  \r\n            displayStream.getVideoTracks()[0].addEventListener(\"ended\", () => {\r\n              if (this.isScreenRecording) {\r\n                this.screenRecorder.stop();\r\n                this.isScreenRecording = false;\r\n                console.log(\"🛑 화면 공유 종료 감지 → 녹화 종료\");\r\n              }\r\n            });\r\n          } catch (err) {\r\n            console.error(\"❌ 화면+오디오 녹화 실패:\", err);\r\n          }\r\n        } else {\r\n          this.screenRecorder.stop();\r\n          this.isScreenRecording = false;\r\n          console.log(\"🛑 화면+마이크 녹화 수동 중지됨\");\r\n        }\r\n      },\r\n    },\r\n  };\r\n  </script>\r\n  "],"mappings":";;;;;;AAkBE,eAAe;EACbA,IAAI,EAAE,iBAAiB;EACvBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACL;MACAC,gBAAgB,EAAE,KAAK;MACvBC,aAAa,EAAE,IAAI;MACnBC,WAAW,EAAE,IAAI;MACjBC,WAAW,EAAE,EAAE;MAEf;MACAC,iBAAiB,EAAE,KAAK;MACxBC,cAAc,EAAE,IAAI;MACpBC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP;IACA,MAAMC,oBAAoBA,CAAA,EAAG;MAC3B,IAAI,CAAC,IAAI,CAACR,gBAAgB,EAAE;QAC1B,IAAI;UACF,IAAI,CAACE,WAAU,GAAI,MAAMO,SAAS,CAACC,YAAY,CAACC,YAAY,CAAC;YAAEC,KAAK,EAAE;UAAK,CAAC,CAAC;UAC7E,IAAI,CAACX,aAAY,GAAI,IAAIY,aAAa,CAAC,IAAI,CAACX,WAAW,CAAC;UACxD,IAAI,CAACC,WAAU,GAAI,EAAE;UAErB,IAAI,CAACF,aAAa,CAACa,eAAc,GAAKC,CAAC,IAAK;YAC1C,IAAIA,CAAC,CAAChB,IAAI,CAACiB,IAAG,GAAI,CAAC,EAAE,IAAI,CAACb,WAAW,CAACc,IAAI,CAACF,CAAC,CAAChB,IAAI,CAAC;UACpD,CAAC;UAED,IAAI,CAACE,aAAa,CAACiB,MAAK,GAAI,MAAM;YAChC,MAAMC,IAAG,GAAI,IAAIC,IAAI,CAAC,IAAI,CAACjB,WAAW,EAAE;cAAEkB,IAAI,EAAE;YAAa,CAAC,CAAC;YAC/D,MAAMC,GAAE,GAAIC,GAAG,CAACC,eAAe,CAACL,IAAI,CAAC;YACrC,MAAMM,CAAA,GAAIC,QAAQ,CAACC,aAAa,CAAC,GAAG,CAAC;YACrCF,CAAC,CAACG,IAAG,GAAIN,GAAG;YACZG,CAAC,CAACI,QAAO,GAAI,sBAAsB;YACnCJ,CAAC,CAACK,KAAK,CAAC,CAAC;YAET,IAAI,IAAI,CAAC5B,WAAW,EAAE;cACpB,IAAI,CAACA,WAAW,CAAC6B,SAAS,CAAC,CAAC,CAACC,OAAO,CAAEC,KAAK,IAAKA,KAAK,CAACC,IAAI,CAAC,CAAC,CAAC;cAC7D,IAAI,CAAChC,WAAU,GAAI,IAAI;YACzB;UACF,CAAC;UAED,IAAI,CAACD,aAAa,CAACkC,KAAK,CAAC,CAAC;UAC1B,IAAI,CAACnC,gBAAe,GAAI,IAAI;UAC5BoC,OAAO,CAACC,GAAG,CAAC,gBAAgB,CAAC;UAE7B,IAAI,CAACnC,WAAW,CAACoC,cAAc,CAAC,CAAC,CAAC,CAAC,CAAC,CAACC,gBAAgB,CAAC,OAAO,EAAE,MAAM;YACnE,IAAI,IAAI,CAACvC,gBAAgB,EAAE;cACzB,IAAI,CAACC,aAAa,CAACiC,IAAI,CAAC,CAAC;cACzB,IAAI,CAAClC,gBAAe,GAAI,KAAK;cAC7BoC,OAAO,CAACC,GAAG,CAAC,mBAAmB,CAAC;YAClC;UACF,CAAC,CAAC;QACJ,EAAE,OAAOG,GAAG,EAAE;UACZJ,OAAO,CAACK,KAAK,CAAC,cAAc,EAAED,GAAG,CAAC;QACpC;MACF,OAAO;QACL,IAAI,CAACvC,aAAa,CAACiC,IAAI,CAAC,CAAC;QACzB,IAAI,CAAClC,gBAAe,GAAI,KAAK;QAC7BoC,OAAO,CAACC,GAAG,CAAC,kBAAkB,CAAC;MACjC;IACF