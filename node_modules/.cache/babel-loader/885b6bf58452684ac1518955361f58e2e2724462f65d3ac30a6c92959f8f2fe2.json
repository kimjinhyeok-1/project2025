y = ref('')\r\nconst fullChat = ref([])\r\n\r\nconst summaryLoading = ref(true)\r\nconst chatLoading = ref(true)\r\n\r\nonMounted(async () => {\r\n  try {\r\n    const summaryRes = await axios.get('http://192.168.50.24:8000/chat/summary')\r\n    summary.value = summaryRes.data\r\n  } catch (err) {\r\n    summary.value = '❌ 요약 데이터를 불러올 수 없습니다.'\r\n  } finally {\r\n    summaryLoading.value = false\r\n  }\r\n\r\n  try {\r\n    const chatRes = await axios.get('http://192.168.50.24:8000/chat/logs')\r\n    fullChat.value = chatRes.data\r\n  } catch (err) {\r\n    fullChat.value = [{ role: 'system', content: '❌ 대화 데이터를 불러올 수 없습니다.' }]\r\n  } finally {\r\n    chatLoading.value = false\r\n  }\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.nav-link {\r\n  cursor: pointer;\r\n}\r\n.tab-content {\r\n  min-height: 200px;\r\n}\r\n</style>\r\n"],"mappings":"AA6DA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,OAAOC,KAAK,MAAM,OAAO;;;;;;;IAEzB,MAAMC,SAAS,GAAGH,GAAG,CAAC,SAAS,CAAC;IAChC,MAAMI,OAAO,GAAGJ,GAAG,CAAC,EAAE,CAAC;IACvB,MAAMK,QAAQ,GAAGL,GAAG,CAAC,EAAE,CAAC;IAExB,MAAMM,cAAc,GAAGN,GAAG,CAAC,IAAI,CAAC;IAChC,MAAMO,WAAW,GAAGP,GAAG,CAAC,IAAI,CAAC;IAE7BC,SAAS,CAAC,YAAY;MACpB,IAAI;QACF,MAAMO,UAAU,GAAG,MAAMN,KAAK,CAACO,GAAG,CAAC,wCAAwC,CAAC;QAC5EL,OAAO,CAACM,KAAK,GAAGF,UAAU,CAACG,IAAI;MACjC,CAAC,CAAC,OAAOC,GAAG,EAAE;QACZR,OAAO,CAACM,KAAK,GAAG,uBAAuB;MACzC,CAAC,SAAS;QACRJ,cAAc,CAACI,KAAK,GAAG,KAAK;MAC9B;MAEA,IAAI;QACF,MAAMG,OAAO,GAAG,MAAMX,KAAK,CAACO,GAAG,CAAC,qCAAqC,CAAC;QACtEJ,QAAQ,CAACK,KAAK,GAAGG,OAAO,CAACF,IAAI;MAC/B,CAAC,CAAC,OAAOC,GAAG,EAAE;QACZP,QAAQ,CAACK,KAAK,GAAG,CAAC;UAAEI,IAAI,EAAE,QAAQ;UAAEC,OAAO,EAAE;QAAwB,CAAC,CAAC;MACzE,CAAC,SAAS;QACRR,WAAW,CAACG,KAAK,GAAG,KAAK;MAC3B;IACF,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}