{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport axios from 'axios';\nexport default {\n  __name: 'ProfessorQnA',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const activeTab = ref('summary');\n    const summary = ref('');\n    const fullChat = ref([]);\n    const summaryLoading = ref(true);\n    const chatLoading = ref(true);\n    onMounted(async () => {\n      try {\n        const summaryRes = await axios.get('http://192.168.50.24:8000/chat/summary');\n        summary.value = summaryRes.data;\n      } catch (err) {\n        summary.value = '❌ 요약 데이터를 불러올 수 없습니다.';\n      } finally {\n        summaryLoading.value = false;\n      }\n      try {\n        const chatRes = await axios.get('http://192.168.50.24:8000/chat/logs');\n        fullChat.value = chatRes.data;\n      } catch (err) {\n        fullChat.value = [{\n          role: 'system',\n          content: '❌ 대화 데이터를 불러올 수 없습니다.'\n        }];\n      } finally {\n        chatLoading.value = false;\n      }\n    });\n    const __returned__ = {\n      activeTab,\n      summary,\n      fullChat,\n      summaryLoading,\n      chatLoading,\n      ref,\n      onMounted,\n      get axios() {\n        return axios;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","axios","activeTab","summary","fullChat","summaryLoading","chatLoading","summaryRes","get","value","data","err","chatRes","role","content"],"sources":["C:/Users/rlaal/abcde/test/src/views/ProfessorQnA.vue"],"sourcesContent":["<template>\r\n  <div class=\"container mt-5\">\r\n    <h2 class=\"text-center\">❓ 질문 & 답변 확인하기</h2>\r\n\r\n    <!-- 탭 버튼 -->\r\n    <ul class=\"nav nav-tabs mt-4\" style=\"justify-content: flex-start;\">\r\n      <li class=\"nav-item\">\r\n        <a class=\"nav-link\" :class=\"{ active: activeTab === 'summary', 'text-primary': true }