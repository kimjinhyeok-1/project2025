{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport { getChatSummary, getChatLogs } from '@/api/professorService';\nexport default {\n  __name: 'ProfessorQnA',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const activeTab = ref('summary');\n    const summary = ref('');\n    const fullChat = ref([]);\n    const summaryLoading = ref(true);\n    const chatLoading = ref(true);\n    onMounted(async () => {\n      try {\n        const summaryRes = await getChatSummary();\n        summary.value = summaryRes;\n      } catch (err) {\n        summary.value = '❌ 요약 데이터를 불러올 수 없습니다.';\n      } finally {\n        summaryLoading.value = false;\n      }\n      try {\n        const chatRes = await getChatLogs();\n        fullChat.value = chatRes;\n      } catch (err) {\n        fullChat.value = [{\n          role: 'system',\n          content: '❌ 대화 데이터를 불러올 수 없습니다.'\n        }];\n      } finally {\n        chatLoading.value = false;\n      }\n    });\n    const __returned__ = {\n      activeTab,\n      summary,\n      fullChat,\n      summaryLoading,\n      chatLoading,\n      ref,\n      onMounted,\n      get getChatSummary() {\n        return getChatSummary;\n      },\n      get getChatLogs() {\n        return getChatLogs;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","getChatSummary","getChatLogs","activeTab","summary","fullChat","summaryLoading","chatLoading","summaryRes","value","err","chatRes","role","content"],"sources":["C:/Users/rlaal/abcde/test/src/views/ProfessorQnA.vue"],"sourcesContent":["<template>\r\n  <div class=\"container mt-5\">\r\n    <h2 class=\"text-center\">❓ 질문 & 답변 확인하기</h2>\r\n\r\n    <!-- 탭 -->\r\n    <ul class=\"nav nav-tabs mt-4\" style=\"justify-content: flex-start;\">\r\n      <li class=\"nav-item\">\r\n        <a class=\"nav-link\" :class=\"{ active: activeTab === 'summary', 'text-primary': true }\" @click=\"activeTab = 'summary'\">요약 보기</a>\r\n      </li>\r\n      <li class=\"nav-item\">\r\n        <a class=\"nav-link\" :class=\"{ active: activeTab === 'fullchat', 'text-primary': true }\" @click=\"activeTab = 'fullchat'\">전체 대화 보기</a>\r\n      </li>\r\n      <li class=\"nav-item\">\r\n        <a class=\"nav-link\" :class=\"{ active: activeTab === 'resources', 'text-primary': true }\" @click=\"activeTab = 'resources'\">자료 보기</a>\r\n      </li>\r\n    </ul>\r\n\r\n    <!-- 내용 -->\r\n    <div class=\"tab-content mt-3 border p-4 rounded bg-white shadow-sm\">\r\n\r\n      <!-- 요약 탭 -->\r\n      <div v-if=\"activeTab === 'summary'\">\r\n        <h5>📋 질문 요약</h5>\r\n        <div v-if=\"summaryLoading\" class=\"d-flex align-items-center\">\r\n          <strong role=\"status\">Loading...</strong>\r\n          <div class=\"spinner-border ms-auto\" aria-hidden=\"true\"></div>\r\n        </div>\r\n        <p v-else>{{ summary }}</p>\r\n      </div>\r\n\r\n      <!-- 전체 대화 탭 -->\r\n      <div v-if=\"activeTab === 'fullchat'\">\r\n        <h5>💬 전체 대화 내용</h5>\r\n        <div v-if=\"chatLoading\" class=\"d-flex align-items-center\">\r\n          <strong role=\"status\">Loading...</strong>\r\n          <div class=\"spinner-border ms-auto\" aria-hidden=\"true\"></div>\r\n        </div>\r\n        <ul v-else class=\"list-group\">\r\n          <li v-for=\"(msg, index) in fullChat\" :key=\"index\" class=\"list-group-item\">\r\n            <strong>{{ msg.role === 'user' ? '학생' : msg.role === 'assistant' ? 'GPT' : '시스템' }}:</strong>\r\n            {{ msg.content }}\r\n          </li>\r\n        </ul>\r\n      </div>\r\n\r\n      <!-- 자료 보기 탭 -->\r\n      <div v-if=\"activeTab === 'resources'\">\r\n        <h5>📂 자료 보기</h5>\r\n        <p>자료 기능은 추후 추가될 예정입니다.</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport { getChatSummary, getChatLogs } from '@/api/professorService'\r\n\r\nconst activeTab = ref('summary')\r\n\r\nconst summary = ref('')\r\nconst fullChat = ref([])\r\n\r\nconst summaryLoading = ref(true)\r\nconst chatLoading = ref(true)\r\n\r\nonMounted(async () => {\r\n  try {\r\n    const summaryRes = await getChatSummary()\r\n    summary.value = summaryRes\r\n  } catch (err) {\r\n    summary.value = '❌ 요약 데이터를 불러올 수 없습니다.'\r\n  } finally {\r\n    summaryLoading.value = false\r\n  }\r\n\r\n  try {\r\n    const chatRes = await getChatLogs()\r\n    fullChat.value = chatRes\r\n  } catch (err) {\r\n    fullChat.value = [{ role: 'system', content: '❌ 대화 데이터를 불러올 수 없습니다.' }]\r\n  } finally {\r\n    chatLoading.value = false\r\n  }\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.nav-link {\r\n  cursor: pointer;\r\n}\r\n.tab-content {\r\n  min-height: 200px;\r\n}\r\n</style>\r\n"],"mappings":"AAuDA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,cAAc,EAAEC,WAAW,QAAQ,wBAAwB;;;;;;;IAEpE,MAAMC,SAAS,GAAGJ,GAAG,CAAC,SAAS,CAAC;IAEhC,MAAMK,OAAO,GAAGL,GAAG,CAAC,EAAE,CAAC;IACvB,MAAMM,QAAQ,GAAGN,GAAG,CAAC,EAAE,CAAC;IAExB,MAAMO,cAAc,GAAGP,GAAG,CAAC,IAAI,CAAC;IAChC,MAAMQ,WAAW,GAAGR,GAAG,CAAC,IAAI,CAAC;IAE7BC,SAAS,CAAC,YAAY;MACpB,IAAI;QACF,MAAMQ,UAAU,GAAG,MAAMP,cAAc,CAAC,CAAC;QACzCG,OAAO,CAACK,KAAK,GAAGD,UAAU;MAC5B,CAAC,CAAC,OAAOE,GAAG,EAAE;QACZN,OAAO,CAACK,KAAK,GAAG,uBAAuB;MACzC,CAAC,SAAS;QACRH,cAAc,CAACG,KAAK,GAAG,KAAK;MAC9B;MAEA,IAAI;QACF,MAAME,OAAO,GAAG,MAAMT,WAAW,CAAC,CAAC;QACnCG,QAAQ,CAACI,KAAK,GAAGE,OAAO;MAC1B,CAAC,CAAC,OAAOD,GAAG,EAAE;QACZL,QAAQ,CAACI,KAAK,GAAG,CAAC;UAAEG,IAAI,EAAE,QAAQ;UAAEC,OAAO,EAAE;QAAwB,CAAC,CAAC;MACzE,CAAC,SAAS;QACRN,WAAW,CAACE,KAAK,GAAG,KAAK;MAC3B;IACF,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}