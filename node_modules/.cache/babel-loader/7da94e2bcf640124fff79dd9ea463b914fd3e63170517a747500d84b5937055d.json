{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref } from 'vue';\nimport { useRouter } from 'vue-router';\nexport default {\n  name: 'HomeView',\n  setup() {\n    const userId = ref('');\n    const password = ref('');\n    const errorMessage = ref('');\n    const router = useRouter();\n    const users = [{\n      id: 'prof001',\n      password: '1234',\n      role: 'teacher',\n      name: '설순옥'\n    }, {\n      id: 'stu001',\n      password: '5678',\n      role: 'student',\n      name: '김민주'\n    }];\n    const handleLogin = () => {\n      const foundUser = users.find(user => user.id === userId.value && user.password === password.value);\n      if (foundUser) {\n        localStorage.setItem('user', JSON.stringify(foundUser));\n        router.push(foundUser.role === 'teacher' ? '/professor' : '/student');\n      } else {\n        errorMessage.value = '아이디 또는 비밀번호가 올바르지 않습니다.';\n      }\n    };\n    return {\n      userId,\n      password,\n      handleLogin,\n      errorMessage\n    };\n  }\n};","map":{"version":3,"names":["ref","useRouter","name","setup","userId","password","errorMessage","router","users","id","role","handleLogin","foundUser","find","user","value","localStorage","setItem","JSON","stringify","push"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\views\\HomeView.vue"],"sourcesContent":["<template>\r\n  <div class=\"bg-gradient-primary min-vh-100 d-flex justify-content-center align-items-center\">\r\n    <div class=\"card o-hidden border-0 shadow-lg my-5\" style=\"width: 400px;\">\r\n      <div class=\"card-body p-5\">\r\n        <!-- 로고 + 제목 -->\r\n        <div class=\"text-center mb-4\">\r\n          <img src=\"/kut_logo.gif\" alt=\"Logo\" class=\"img-fluid mb-3\" style=\"width: 60px;\" />\r\n          <h1 class=\"h4 text-gray-900 mb-1\">KOREATECH</h1>\r\n          <p class=\"text-gray-600 mb-4\">온라인 교육 로그인</p>\r\n        </div>\r\n\r\n        <!-- 로그인 폼 -->\r\n        <form @submit.prevent=\"handleLogin\" class=\"user\">\r\n          <div class=\"form-group mb-3\">\r\n            <input\r\n              v-model=\"userId\"\r\n              type=\"text\"\r\n              class=\"form-control form-control-user\"\r\n              placeholder=\"아이디\"\r\n              required\r\n            />\r\n          </div>\r\n          <div class=\"form-group mb-3\">\r\n            <input\r\n              v-model=\"password\"\r\n              type=\"password\"\r\n              class=\"form-control form-control-user\"\r\n              placeholder=\"비밀번호\"\r\n              required\r\n            />\r\n          </div>\r\n          <button type=\"submit\" class=\"btn btn-primary btn-user w-100\">\r\n            로그인\r\n          </button>\r\n        </form>\r\n\r\n        <!-- 에러 메시지 -->\r\n        <p v-if=\"errorMessage\" class=\"text-danger text-center mt-3 small\">\r\n          {{ errorMessage }}\r\n        </p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\n\r\nexport default {\r\n  name: 'HomeView',\r\n  setup() {\r\n    const userId = ref('')\r\n    const password = ref('')\r\n    const errorMessage = ref('')\r\n    const router = useRouter()\r\n\r\n    const users = [\r\n      { id: 'prof001', password: '1234', role: 'teacher', name: '설순옥' },\r\n      { id: 'stu001', password: '5678', role: 'student', name: '김민주' },\r\n    ]\r\n\r\n    const handleLogin = () => {\r\n      const foundUser = users.find(\r\n        (user) => user.id === userId.value && user.password === password.value\r\n      )\r\n\r\n      if (foundUser) {\r\n        localStorage.setItem('user', JSON.stringify(foundUser))\r\n        router.push(foundUser.role === 'teacher' ? '/professor' : '/student')\r\n      } else {\r\n        errorMessage.value = '아이디 또는 비밀번호가 올바르지 않습니다.'\r\n      }\r\n    }\r\n\r\n    return {\r\n      userId,\r\n      password,\r\n      handleLogin,\r\n      errorMessage\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.bg-gradient-primary {\r\n  background: linear-gradient(180deg, #4e73df 10%, #224abe 100%);\r\n  background-size: cover;\r\n}\r\n\r\n.card {\r\n  border-radius: 1rem;\r\n}\r\n\r\n.form-control-user {\r\n  border-radius: 10rem;\r\n  padding: 0.75rem 1rem;\r\n  font-size: 0.9rem;\r\n}\r\n\r\n.btn-user {\r\n  border-radius: 10rem;\r\n  padding: 0.75rem 1rem;\r\n  font-size: 0.9rem;\r\n}\r\n</style>\r\n"],"mappings":";AA8CA,SAASA,GAAE,QAAS,KAAI;AACxB,SAASC,SAAQ,QAAS,YAAW;AAErC,eAAe;EACbC,IAAI,EAAE,UAAU;EAChBC,KAAKA,CAAA,EAAG;IACN,MAAMC,MAAK,GAAIJ,GAAG,CAAC,EAAE;IACrB,MAAMK,QAAO,GAAIL,GAAG,CAAC,EAAE;IACvB,MAAMM,YAAW,GAAIN,GAAG,CAAC,EAAE;IAC3B,MAAMO,MAAK,GAAIN,SAAS,CAAC;IAEzB,MAAMO,KAAI,GAAI,CACZ;MAAEC,EAAE,EAAE,SAAS;MAAEJ,QAAQ,EAAE,MAAM;MAAEK,IAAI,EAAE,SAAS;MAAER,IAAI,EAAE;IAAM,CAAC,EACjE;MAAEO,EAAE,EAAE,QAAQ;MAAEJ,QAAQ,EAAE,MAAM;MAAEK,IAAI,EAAE,SAAS;MAAER,IAAI,EAAE;IAAM,CAAC,CAClE;IAEA,MAAMS,WAAU,GAAIA,CAAA,KAAM;MACxB,MAAMC,SAAQ,GAAIJ,KAAK,CAACK,IAAI,CACzBC,IAAI,IAAKA,IAAI,CAACL,EAAC,KAAML,MAAM,CAACW,KAAI,IAAKD,IAAI,CAACT,QAAO,KAAMA,QAAQ,CAACU,KACnE;MAEA,IAAIH,SAAS,EAAE;QACbI,YAAY,CAACC,OAAO,CAAC,MAAM,EAAEC,IAAI,CAACC,SAAS,CAACP,SAAS,CAAC;QACtDL,MAAM,CAACa,IAAI,CAACR,SAAS,CAACF,IAAG,KAAM,SAAQ,GAAI,YAAW,GAAI,UAAU;MACtE,OAAO;QACLJ,YAAY,CAACS,KAAI,GAAI,yBAAwB;MAC/C;IACF;IAEA,OAAO;MACLX,MAAM;MACNC,QAAQ;MACRM,WAAW;MACXL;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}