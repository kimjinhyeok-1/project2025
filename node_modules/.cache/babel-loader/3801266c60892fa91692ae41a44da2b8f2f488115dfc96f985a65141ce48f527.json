{"ast":null,"code":"import { getSummaryById } from \"@/api/sttService\";\nexport default {\n  name: \"ProfessorSummaryDetailView\",\n  data() {\n    return {\n      summary: null\n    };\n  },\n  async mounted() {\n    const id = this.$route.params.id;\n    try {\n      this.summary = await getSummaryById(id);\n    } catch (error) {\n      console.error(\"요약 상세 조회 실패:\", error);\n    }\n  }\n};","map":{"version":3,"names":["getSummaryById","name","data","summary","mounted","id","$route","params","error","console"],"sources":["C:\\Users\\rlaal\\abcde\\test\\src\\views\\ProfessorSummaryDetailView.vue"],"sourcesContent":["<template>\r\n    <div class=\"summary-detail text-center mt-5\">\r\n      <h2>📄 수업 요약 상세 보기</h2>\r\n      <p class=\"text-muted\">요약된 내용을 아래에서 확인하세요.</p>\r\n  \r\n      <div v-if=\"summary\" class=\"summary-box mt-4 p-4\">\r\n        <h4>{{ summary.title }}</h4>\r\n        <p><strong>🗓 날짜:</strong> {{ summary.date }}</p>\r\n        <hr />\r\n        <p style=\"white-space: pre-wrap; text-align: left;\">{{ summary.content }}</p>\r\n      </div>\r\n  \r\n      <div v-else>\r\n        <p>요약 데이터를 불러오는 중입니다...</p>\r\n      </div>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import { getSummaryById } from \"@/api/sttService\";\r\n  \r\n  export default {\r\n    name: \"ProfessorSummaryDetailView\",\r\n    data() {\r\n      return {\r\n        summary: null,\r\n      };\r\n    },\r\n    async mounted() {\r\n      const id = this.$route.params.id;\r\n      try {\r\n        this.summary = await getSummaryById(id);\r\n      } catch (error) {\r\n        console.error(\"요약 상세 조회 실패:\", error);\r\n      }\r\n    },\r\n  };\r\n  </script>\r\n  \r\n  <style scoped>\r\n  .summary-detail {\r\n    max-width: 900px;\r\n    margin: auto;\r\n    padding: 30px;\r\n  }\r\n  .summary-box {\r\n    background-color: #f8f9fa;\r\n    border-radius: 12px;\r\n    box-shadow: 0 0 6px rgba(0, 0, 0, 0.05);\r\n    text-align: left;\r\n  }\r\n  </style>\r\n  "],"mappings":"