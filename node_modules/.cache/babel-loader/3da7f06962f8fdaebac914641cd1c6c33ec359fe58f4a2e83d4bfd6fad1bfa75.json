radius: 12px;\r\n    box-shadow: 0 0 6px rgba(0, 0, 0, 0.05);\r\n  }\r\n  </style>"],"mappings":"AAyBE,SAASA,YAAW,QAAS,kBAAkB;AAE/C,eAAe;EACbC,IAAI,EAAE,qBAAqB;EAC3BC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE;IACb,CAAC;EACH,CAAC;EACD,MAAMC,OAAOA,CAAA,EAAG;IACd,IAAI;MACF,IAAI,CAACD,SAAQ,GAAI,MAAMH,YAAY,CAAC,CAAC;IACvC,EAAE,OAAOK,KAAK,EAAE;MACdC,OAAO,CAACD,KAAK,CAAC,gBAAgB,EAAEA,KAAK,CAAC;IACxC;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}